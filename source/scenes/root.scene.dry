title: Root Scene
new-page: true
on-arrival: {!
// The sidebar/status renderer runs before the player presses Start Game.
// Keep a display-safe baseline state available on the start menu without marking the game as started.
if (Q.startup_state_defaults_initialized !== 1 && Q.started !== 1) {
    Q.startup_state_defaults_initialized = 1;
    Q.started = 0;
    Q.time = 1;
    Q.year = 1928;
    Q.month = 1;
    Q.month_actions = 0;
    Q.difficulty = 0;
    Q.historical_mode = 0;
    Q.old_demographics = 0;
    Q.use_decimals = 0;
    Q.resources = 2;
    Q.dues = 2;
    Q.dissent = 0.05;
    Q.dissent_percent = 5;

    Q.factions = ['ddp_left_progressive', 'ddp_laborist', 'ddp_left_liberal', 'ddp_left_bourgeois', 'ddp_regionalist'];
    Q.ddp_factions = Q.factions;
    for (var startupDdpFaction of Q.ddp_factions) {
        Q[startupDdpFaction] = 0;
        Q[startupDdpFaction + '_dissent'] = 0;
    }
    Q.ddp_faction_dissent_variables = ['ddp_left_progressive_dissent', 'ddp_laborist_dissent', 'ddp_left_liberal_dissent', 'ddp_left_bourgeois_dissent', 'ddp_regionalist_dissent'];
    Q.ddp_ideology_variables = ['ddp_nationalism_position', 'ddp_economic_position', 'ddp_republic_position', 'ddp_federalism_position', 'ddp_leader'];
    Q.ddp_nationalism_position = 0;
    Q.ddp_economic_position = 0;
    Q.ddp_republic_position = 0;
    Q.ddp_federalism_position = 0;
    Q.ddp_leader = 0;
    Q.ddp_congress_dates = ['1925-12', '1927-04', '1929-10', '1931-03', '1933-08'];

    Q.deprecated_spd_faction_vars = ['left_strength', 'left_dissent', 'center_strength', 'center_dissent', 'labor_strength', 'labor_dissent', 'reformist_strength', 'reformist_dissent', 'neorevisionist_strength', 'neorevisionist_dissent'];
    Q.left_strength = 15;
    Q.left_dissent = 20;
    Q.center_strength = 30;
    Q.center_dissent = 0;
    Q.labor_strength = 25;
    Q.labor_dissent = 5;
    Q.reformist_strength = 25;
    Q.reformist_dissent = 5;
    Q.neorevisionist_strength = 5;
    Q.neorevisionist_dissent = 10;

    Q.simplified_faction_variables = ['dnvp_left', 'dnvp_right', 'dvp_left', 'dvp_right', 'spd_left', 'spd_right'];
    Q.dnvp_left = 50;
    Q.dnvp_right = 50;
    Q.dvp_left = 50;
    Q.dvp_right = 50;
    Q.spd_left = 50;
    Q.spd_right = 50;

    Q.z_relation = 50;
    Q.bvp_relation = 50;
    Q.wp_relation = 50;
    Q.kpd_relation = 25;
    Q.ddp_relation = 60;
    Q.dvp_relation = 35;
    Q.dnvp_relation = 10;
    Q.nsdap_relation = 0;

    Q.presidential_anger = 0;
    Q.federalism = 50;
    Q.nationalism = 60;
    Q.socialism = 40;
    Q.pro_republic = 59;
    Q.pacifism = 50;
    Q.secularism = 50;
    Q.elite_support = 50;
    Q.elite_support_2 = '50';

    Q.president = "Hindenburg";
    Q.chancellor = "Marx";
    Q.chancellor_party = 'Z';
    Q.spd_in_government = 0;
    Q.z_in_government = 1;
    Q.bvp_in_government = 0;
    Q.ddp_in_government = 0;
    Q.dvp_in_government = 1;
    Q.wp_in_government = 0;
    Q.dnvp_in_government = 1;
    Q.kpd_in_government = 0;
    Q.nsdap_in_government = 0;
    Q.spd_caretaker = 0;
    Q.spd_toleration = 0;
    Q.in_right_coalition = 0;
    Q.in_weimar_coalition = 0;
    Q.in_grand_coalition = 0;
    Q.in_popular_front = 0;
    Q.in_left_front = 0;
    Q.in_emergency_government = 0;
    Q.in_spd_majority = 0;
    Q.in_minority_government = 0;
    Q.minority_government = 0;
    Q.coalition_dissent = 0;
    Q.kpd_coalition_dissent = 0;

    Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployed', 'catholics'];
    Q.parties = ['spd', 'kpd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'other'];
    Q.party_leader_ideology_parties = ['spd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'kpd'];
    for (var startupTrackerParty of Q.party_leader_ideology_parties) {
        Q[startupTrackerParty + '_leader'] = 0;
        Q[startupTrackerParty + '_ideology'] = 0;
    }
    Q.ddp_leader = 0;
    Q.kpd_leader = 1;
    Q.z_leader = 2;
    Q.nsdap_leader = 3;
    Q.dvp_ideology = 1;
    Q.sapd_formed = 0;
    Q.sapd_r = 0;
    Q.old_sapd_r = 0;
    Q.ddp_name = "DDP";

    var startupReichstag = {spd: 130, kpd: 45, z: 70, bvp: 15, ddp: 30, dvp: 50, wp: 20, dnvp: 100, nsdap: 15, other: 25, sapd: 0};
    var startupVoteShare = {spd: 26, kpd: 9, z: 14, bvp: 3, ddp: 6, dvp: 10, wp: 4, dnvp: 20, nsdap: 3, other: 5, sapd: 0};
    for (var startupParty in startupReichstag) {
        Q[startupParty + '_r'] = startupReichstag[startupParty];
        Q['old_' + startupParty + '_r'] = startupReichstag[startupParty];
        Q[startupParty + '_result_votes'] = startupVoteShare[startupParty];
        Q[startupParty + '_r_disp'] = startupVoteShare[startupParty].toFixed(1);
        Q[startupParty + '_seat_share_disp'] = (startupReichstag[startupParty]/5).toFixed(1);
        Q['old_' + startupParty + '_votes'] = startupVoteShare[startupParty];
        Q['old_' + startupParty + '_votes_disp'] = startupVoteShare[startupParty].toFixed(1);
        Q[startupParty + '_votes'] = startupVoteShare[startupParty];
        Q[startupParty + '_votes_disp'] = startupVoteShare[startupParty].toFixed(1);
        Q[startupParty + '_votes_display'] = startupVoteShare[startupParty].toFixed(1);
    }
    Q.reichstag_seat_count = 500;
    Q.reichstag_total_seats = 500;
    Q.reichstag_seat_allocation_valid = 1;

    Q.coalition_members = ['ddp'];
    Q.coalition_selected_party = '';
    Q.coalition_negotiation_points = 0;
    Q.coalition_required_points = 0;
    Q.coalition_total_seats = Q.ddp_r;
    Q.coalition_member_list_text = 'DDP';
    Q.coalition_blocked_parties_text = 'None';
    Q.coalition_unavailable_parties_text = 'None';
    Q.coalition_selected_concessions_text = 'None';
    Q.coalition_selected_blocks_text = 'None beyond party incompatibilities';
    Q.coalition_negotiation_active = 0;
    Q.coalition_spd_member = 0;
    Q.coalition_kpd_member = 0;
    Q.coalition_z_member = 0;
    Q.coalition_bvp_member = 0;
    Q.coalition_ddp_member = 1;
    Q.coalition_dvp_member = 0;
    Q.coalition_wp_member = 0;
    Q.coalition_dnvp_member = 0;
    Q.coalition_nsdap_member = 0;
    Q.in_custom_negotiated_coalition = 0;
    Q.coalition_nsdap_z_allowed = 0;
    Q.coalition_kpd_z_allowed = 0;
    Q.coalition_toleration_party = '';

    Q.budget = 4;
    Q.inflation = 2.9;
    Q.inflation_2 = '2.9';
    Q.unemployed = 8.6;
    Q.unemployed_2 = '8.6';
    Q.economic_growth = 4.4;
    Q.economic_growth_2 = '4.4';
    Q.black_thursday_seen = 0;

    Q.next_election_year = 1928;
    Q.next_election_month = 5;
    Q.next_election_time = 5;
    Q.n_elections = 0;

    Q.workers = 48;
    Q.old_middle = 13;
    Q.new_middle = 14;
    Q.rural = 25;
    Q.catholics = 30;
    var startupClassVotes = {
        workers: {spd: 60, kpd: 20, z: 5, bvp: 0, ddp: 0, dvp: 0, wp: 0, dnvp: 5, nsdap: 0, other: 10},
        old_middle: {spd: 5, kpd: 0, z: 4, bvp: 2, ddp: 10, dvp: 24, wp: 4, dnvp: 25, nsdap: 10, other: 8},
        new_middle: {spd: 5, kpd: 1, z: 9, bvp: 1, ddp: 25, dvp: 24, wp: 4, dnvp: 10, nsdap: 5, other: 12},
        rural: {spd: 10, kpd: 0, z: 4, bvp: 3, ddp: 5, dvp: 15, wp: 1, dnvp: 45, nsdap: 5, other: 9},
        unemployed: {spd: 25, kpd: 55, z: 1, bvp: 0, ddp: 0, dvp: 0, wp: 0, dnvp: 5, nsdap: 15, other: 9},
        catholics: {spd: 15, kpd: 2, z: 41, bvp: 9, ddp: 0, dvp: 5, wp: 2, dnvp: 5, nsdap: 0, other: 10}
    };
    for (var startupClass in startupClassVotes) {
        var startupClassTotal = 0;
        for (var startupVoteParty in startupClassVotes[startupClass]) {
            Q[startupClass + '_' + startupVoteParty] = startupClassVotes[startupClass][startupVoteParty];
            startupClassTotal += startupClassVotes[startupClass][startupVoteParty];
        }
        for (var startupDisplayParty in startupClassVotes[startupClass]) {
            var startupNormalized = 100*startupClassVotes[startupClass][startupDisplayParty]/startupClassTotal;
            Q[startupClass + '_' + startupDisplayParty + '_normalized'] = startupNormalized;
            Q[startupClass + '_' + startupDisplayParty + '_display'] = (Math.round(startupNormalized*10)/10).toFixed(1);
        }
    }
}
!}
go-to: post_event if started = 1; start_menu if started = 0

@start_menu
new-page: true
go-to: start_menu_2

= Social Democracy: An Alternate History

@start_menu_2

- @start: Start game
- @election_simulation: Election simulation
- @credits: Credits
- @game_over.achievements


@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 1928;
Q.month = 1;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// DDP factions
Q.factions = ['ddp_left_progressive', 'ddp_laborist', 'ddp_left_liberal', 'ddp_left_bourgeois', 'ddp_regionalist'];
Q.ddp_factions = Q.factions;
Q.ddp_left_progressive = 0;
Q.ddp_laborist = 0;
Q.ddp_left_liberal = 0;
Q.ddp_left_bourgeois = 0;
Q.ddp_regionalist = 0;
Q.ddp_faction_dissent_variables = ['ddp_left_progressive_dissent', 'ddp_laborist_dissent', 'ddp_left_liberal_dissent', 'ddp_left_bourgeois_dissent', 'ddp_regionalist_dissent'];
Q.ddp_left_progressive_dissent = 0;
Q.ddp_laborist_dissent = 0;
Q.ddp_left_liberal_dissent = 0;
Q.ddp_left_bourgeois_dissent = 0;
Q.ddp_regionalist_dissent = 0;

// DDP congress ideology/state variables. Codes are displayed through DDP qdisplays and status labels.
Q.ddp_ideology_variables = ['ddp_nationalism_position', 'ddp_economic_position', 'ddp_republic_position', 'ddp_federalism_position', 'ddp_leader'];
Q.ddp_nationalism_position = 0;
Q.ddp_economic_position = 0;
Q.ddp_republic_position = 0;
Q.ddp_federalism_position = 0;
Q.ddp_leader = 0;
Q.ddp_congress_dates = ['1925-12', '1927-04', '1929-10', '1931-03', '1933-08'];

// Deprecated SPD faction compatibility variables.
// TODO(DDP factions): Migrate remaining SPD faction effects/conditions to DDP faction variables during future rebalancing.
Q.deprecated_spd_faction_vars = ['left_strength', 'left_dissent', 'center_strength', 'center_dissent', 'labor_strength', 'labor_dissent', 'reformist_strength', 'reformist_dissent', 'neorevisionist_strength', 'neorevisionist_dissent'];
Q.left_strength = 15;
Q.left_dissent = 20;
Q.center_strength = 30;
Q.center_dissent = 0;
Q.labor_strength = 25;
Q.labor_dissent = 5;
Q.reformist_strength = 25;
Q.reformist_dissent = 5;
Q.neorevisionist_strength = 5;
Q.neorevisionist_dissent = 10;

// Simplified faction variables for party-level internal tendencies.
// left = moderate/parliamentary tendency.
// right = nationalist/authoritarian or radical tendency depending on party.
// These qualities are registered separately with 0..100 clamps and can be
// modified by events, checked in conditionals, or referenced from scripts.
Q.simplified_faction_variables = ['dnvp_left', 'dnvp_right', 'dvp_left', 'dvp_right', 'spd_left', 'spd_right'];
Q.simplified_faction_pairs = [
    {party: 'dnvp', left: 'dnvp_left', right: 'dnvp_right'},
    {party: 'dvp', left: 'dvp_left', right: 'dvp_right'},
    {party: 'spd', left: 'spd_left', right: 'spd_right'}
];
Q.simplified_faction_axis = {
    left: 'moderate/parliamentary tendency',
    right: 'nationalist/authoritarian or radical tendency depending on party'
};
Q.dnvp_left = 50;
Q.dnvp_right = 50;
Q.dvp_left = 50;
Q.dvp_right = 50;
Q.spd_left = 50;
Q.spd_right = 50;

// secret events...
Q.unions_independent = 0;
Q.centrists_resign = 0;
Q.left_split = 0;
Q.reformists_resigned = 0;

// have we discovered neorevisionism?
Q.neorevisionism = 0;

// crisis_urgency indicates how seriously the SPD is taking the economic crisis - scale from 0 to 10.
Q.crisis_urgency = 0;
// nazi_urgency indicates how seriously the SPD takes the nazis - scale from 0 to 10.
Q.nazi_urgency = 0;
// radicalization indicates how radical the SPD's rhetoric is - scale from 0 to 10.
Q.radicalization = 0;
// Support for the WTB plan and proto-Keynesian works creation plans in general
Q.wtb_support = 0;
// Pacifism is the general anti-militarist/diplomatic political atmosphere relative to 1928.
Q.pacifism = 50;
// Support for democratic reform within the SPD relative to 1928
Q.democratization = 0;
// Support for a communist coalition relative to 1928
Q.communist_coalition = 0;
// economic_plan: have we adopted *any* economic plan?
// 1 - WTB plan, 2 - AfA-bund plan, 3 - radical plan (mass nationalization of industries)
Q.economic_plan = 0;
// have we officially adopted the WTB plan?
Q.wtb_adopted = 0;
// have we formed the iron front?
Q.iron_front_formed = 0;
// people's party support
Q.peoples_party_support = 0;
// support for nationalizations
Q.nationalization_support = 0;
Q.nationalization_adopted = 0;
// moderate economic plan
Q.moderate_plan_support = 0;
Q.moderate_plan_adopted = 0;

// organizations

// inter-party relations
Q.z_relation = 50;
Q.bvp_relation = 50;
Q.wp_relation = 50;
Q.kpd_relation = 25;
Q.ddp_relation = 60;
Q.dvp_relation = 35;
// DNVP and NSDAP are invariably hostile
Q.dnvp_relation = 10;
Q.nsdap_relation = 0;

Q.party_leader_ideology_parties = ['spd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'kpd'];
for (var trackerParty of Q.party_leader_ideology_parties) {
    Q[trackerParty + '_leader'] = 0;
    Q[trackerParty + '_ideology'] = 0;
}
Q.ddp_leader = 0;
Q.kpd_leader = 1;
// alternative is the Conciliators as party leader
Q.kpd_party_leader = "Thälmann";
Q.z_leader = 2;
// party leader - can be Ludwig Kaas, Joseph Joos, or Adam Stegerwald after the 1928 December conference. Joos will be most friendly to the SPD.
Q.z_party_leader = "Marx";
Q.nsdap_leader = 3;
Q.dvp_ideology = 1;

// hmm... maybe we can play nice with Hindenburg???
Q.hindenburg_relation = 25;
// Represents presidential hostility toward parliamentary governance and the current coalition.
Q.presidential_anger = 0;
// whether or not hindenburg can dismiss the government.
Q.hindenburg_enabled = 0;


// Does the SPD lead in Prussia?
// TODO: Potential future consolidation with federalism once Prussia-state relations mechanics are implemented; preserve existing Prussian control logic for now.
Q.spd_prussia = 1;
// Options: spd, z, dnvp, papen, nsdap
Q.prussian_government = "SPD";

// The array of forces - paramilitary groups
// Number of members in 1928 (in thousands)
// Reichsbanner, stahlhelm, SA, rotfrontkämpferbund
Q.rb_strength = 2000;
Q.rb_militancy = 0.01;
Q.women_in_rb = 0;
Q.rb_banned = 0;
Q.sh_strength = 500;
Q.sh_militancy = 0.5;
Q.sh_banned = 0;
Q.sh_banned_prussia = 0;
Q.sa_strength = 80;
Q.sa_militancy = 0.5;
Q.sa_banned = 0;
Q.sa_banned_prussia = 0;
Q.rfb_strength = 130;
Q.rfb_militancy = 0.5;
Q.rfb_banned = 0;
Q.rfb_banned_prussia = 0;

Q.interior_police_strength = 50;
Q.interior_police_militancy = 1;
Q.interior_police_loyalty = 0.45;

Q.prussian_police_strength = 90;
Q.prussian_police_militancy = 1;
Q.prussian_police_loyalty = 0.5;

// strength includes actual military and de facto reserves?
Q.reichswehr_strength = 100;
Q.reichswehr_militancy = 5;
Q.reichswehr_loyalty = 0.2;

// The state of the country

// popular opinion
Q.culture_registry_version = 1;
Q.culture_vars = ['pro_republic', 'pacifism', 'nationalism', 'secularism'];
Q.culture_var_registry = {
    pro_republic: {
        min: 0,
        max: 100,
        default: 59,
        description: 'Support for republican/parliamentary constitutional legitimacy.'
    },
    pacifism: {
        min: 0,
        max: 100,
        default: 50,
        description: 'Public opposition to militarism and support for diplomatic/non-military solutions.'
    },
    nationalism: {
        min: 0,
        max: 100,
        default: 60,
        description: 'Level of nationalist/revanchist political sentiment.'
    },
    secularism: {
        min: 0,
        max: 100,
        default: 50,
        description: 'Support for secular public institutions over confessional/religious influence.'
    }
};
if (typeof window !== 'undefined') {
window.cultureVarRegistry = Q.culture_var_registry;
window.clampCultureVars = function(qualities) {
    for (var i = 0; i < qualities.culture_vars.length; i++) {
        var cultureVar = qualities.culture_vars[i];
        var registryEntry = qualities.culture_var_registry[cultureVar];
        if (typeof qualities[cultureVar] !== 'number' || isNaN(qualities[cultureVar])) {
            qualities[cultureVar] = registryEntry.default;
        }
        qualities[cultureVar] = Math.round(qualities[cultureVar]);
        if (qualities[cultureVar] < registryEntry.min) {
            qualities[cultureVar] = registryEntry.min;
        } else if (qualities[cultureVar] > registryEntry.max) {
            qualities[cultureVar] = registryEntry.max;
        }
    }
};
window.modifyCultureVar = function(qualities, cultureVar, amount) {
    if (qualities.culture_vars.indexOf(cultureVar) < 0) {
        return;
    }
    qualities[cultureVar] += amount;
    window.clampCultureVars(qualities);
};
window.checkCultureVar = function(qualities, cultureVar, operator, target) {
    var value = qualities[cultureVar];
    if (operator === '>=') { return value >= target; }
    if (operator === '>') { return value > target; }
    if (operator === '<=') { return value <= target; }
    if (operator === '<') { return value < target; }
    if (operator === '!=') { return value !== target; }
    return value === target;
};
}
// Level of nationalist/revanchist political sentiment.
// Represents support for federal/regional autonomy versus political centralization.
// TODO: Potential future consolidation with Prussian state-government mechanics, BVP regional politics, state integration, judicial federalization, regional crises, and Prussia-state relations.
Q.federalism = 50;
// national ideology - on a binary scale
// nationalism vs internationalism, pacifism, or non-nationalism
Q.nationalism = 60;
// socialism vs capitalism
Q.socialism = 40;
// Support for republican/parliamentary constitutional legitimacy.
Q.pro_republic = 59;
// Public opposition to militarism and support for diplomatic/non-military solutions.
Q.pacifism = 50;
// Support for secular public institutions over confessional/religious influence.
Q.secularism = 50;

Q.emergency_rule = 0;

// minimum percentage of votes to be represented in the Reichstag
Q.electoral_threshold = 0;
// Seat allocation uses a simplified 500-seat Reichstag for election and coalition mechanics.
Q.reichstag_seat_count = 500;
Q.reichstag_total_seats = 500;
Q.reichstag_seat_allocation_valid = 1;
// constitutional reform level
Q.constitutional_reform = 0;
// constructive vote of no confidence
Q.constructive_vonc = 0;
// reduction in presidential powers
Q.presidential_powers = 0;
// allows banning of non-constitutional parties
Q.constitutional_protection = 0;
Q.kpd_banned = 0;
Q.nsdap_banned = 0;

// coups and capital strikes happen when you upset the right or the capitalists too much with your policies. they're an additional check on your policies, when purely electoral checks don't suffice.
// when coup_progress reaches 10 or capital_strike_progress reaches 10, there's a special event that launches the coup.
Q.coup_progress = 0;
// Deprecated: capital_strike_progress is retained for legacy capital-strike event logic.
// TODO: capital_strike_progress is deprecated; migrate this gameplay logic to elite_support in a future balance pass.
Q.capital_strike_progress = 0;
// Represents elite/business confidence in the government and constitutional system.
Q.elite_support = 50;
Q.elite_support_min = 0;
Q.elite_support_max = 100;
Q.elite_support_description = "Represents elite/business confidence in the government and constitutional system.";

Q.gameplay_variable_registry = {
    'elite_support': {
        'default': 50,
        'min': 0,
        'max': 100,
        'description': "Represents elite/business confidence in the government and constitutional system.",
        'helpers': ['increaseEliteSupport', 'decreaseEliteSupport', 'modifyEliteSupport', 'hasEliteSupportAtLeast', 'hasEliteSupportAtMost']
    },
    'capital_strike_progress': {
        'default': 0,
        'deprecated': true,
        'replacement': 'elite_support'
    }
};
Q.gameplay_variables = Object.keys(Q.gameplay_variable_registry);

if (typeof globalThis !== "undefined") {
    globalThis.clampEliteSupport = function(qualities) {
        if (qualities.elite_support === undefined || qualities.elite_support === null || isNaN(qualities.elite_support)) {
            qualities.elite_support = 50;
        }
        qualities.elite_support = Math.max(0, Math.min(100, qualities.elite_support));
        return qualities.elite_support;
    };
    globalThis.modifyEliteSupport = function(qualities, amount) {
        qualities.elite_support = (qualities.elite_support === undefined || qualities.elite_support === null || isNaN(qualities.elite_support) ? 50 : qualities.elite_support) + amount;
        return globalThis.clampEliteSupport(qualities);
    };
    globalThis.increaseEliteSupport = function(qualities, amount) {
        return globalThis.modifyEliteSupport(qualities, Math.abs(amount));
    };
    globalThis.decreaseEliteSupport = function(qualities, amount) {
        return globalThis.modifyEliteSupport(qualities, -Math.abs(amount));
    };
    globalThis.hasEliteSupportAtLeast = function(qualities, threshold) {
        return globalThis.clampEliteSupport(qualities) >= threshold;
    };
    globalThis.hasEliteSupportAtMost = function(qualities, threshold) {
        return globalThis.clampEliteSupport(qualities) <= threshold;
    };
}

// Reusable coalition negotiation state.
