var initialVoteShareParties = Q.parties.concat(['sapd']);
for (var initialVoteShareParty of initialVoteShareParties) {
    Q[initialVoteShareParty + '_result_votes'] = Q[initialVoteShareParty + '_r'] || 0;
    Q[initialVoteShareParty + '_r_disp'] = Q[initialVoteShareParty + '_result_votes'].toFixed(1);
    Q[initialVoteShareParty + '_seat_share_disp'] = (Math.round((100*(Q[initialVoteShareParty + '_r'] || 0)/Q.reichstag_seat_count)*10)/10).toFixed(1);
    Q['old_' + initialVoteShareParty + '_votes'] = Q['old_' + initialVoteShareParty + '_r'] || 0;
    Q['old_' + initialVoteShareParty + '_votes_disp'] = Q['old_' + initialVoteShareParty + '_votes'].toFixed(1);
}

// for changing the DDP's name to the DStP
Q.ddp_name = "DDP";

// array of objects of the form {date: Date(), spd: 10, kpd: 12, ...} for each election
Q.election_records = [];
// party support records for every month
Q.party_support_records = [];
// inflation and unemployment records
Q.economic_records = [];
// federalism/regional-autonomy records for future audit/index views
Q.political_records = [];

// Variable registries for scripted events, debug/state inspectors, and future audit/index systems.
Q.core_state_variables = ['presidential_anger', 'elite_support', 'federalism', 'pro_republic', 'pacifism', 'nationalism', 'secularism'];
for (var ddpIdeologyVariable of Q.ddp_ideology_variables) {
    if (Q.core_state_variables.indexOf(ddpIdeologyVariable) < 0) {
        Q.core_state_variables.push(ddpIdeologyVariable);
    }
}
for (var ddpDissentVariable of Q.ddp_faction_dissent_variables) {
    if (Q.core_state_variables.indexOf(ddpDissentVariable) < 0) {
        Q.core_state_variables.push(ddpDissentVariable);
    }
}
Q.party_leader_ideology_variables = [];
for (var trackerVariableParty of Q.party_leader_ideology_parties) {
    Q.party_leader_ideology_variables.push(trackerVariableParty + '_leader');
    Q.party_leader_ideology_variables.push(trackerVariableParty + '_ideology');
}
Q.scripted_event_variables = Q.core_state_variables.concat(Q.ddp_factions, Q.ddp_faction_dissent_variables, Q.ddp_ideology_variables, Q.simplified_faction_variables, Q.party_leader_ideology_variables);
Q.debug_state_variables = Q.scripted_event_variables;
