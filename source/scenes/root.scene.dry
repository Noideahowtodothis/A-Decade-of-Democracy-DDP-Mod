on-arrival: difficulty = -1; resources = 4; dues = 3; rb_strength = 2500; kpd_relation = 29; z_relation = 54; bvp_relation = 54; wp_relation = 50; dvp_relation = 49; budget = 5;
go-to: 1928_main

