// Keep Prussian Landtag projections in sync with the current federal support numbers.
// The official Prussian Landtag election event freezes these same calculated results.
if (typeof window !== 'undefined' && typeof window.allocateDhondtSeats !== 'function') {
    window.allocateDhondtSeats = function(partyValues, totalSeats, threshold, options) {
        options = options || {};
        threshold = Number(threshold) || 0;
        totalSeats = Math.max(0, Math.floor(Number(totalSeats) || 0));
        var parties = options.parties || Object.keys(partyValues || {});
        var banned = options.banned || {};
        var allocatedSeats = {};
        var eligibleParties = [];
        for (var partyIndex = 0; partyIndex < parties.length; partyIndex++) {
            var allocationParty = parties[partyIndex];
            var partyValue = Number(partyValues[allocationParty]) || 0;
            allocatedSeats[allocationParty] = 0;
            if (!banned[allocationParty] && partyValue > 0 && (threshold <= 0 || partyValue >= threshold)) {
                eligibleParties.push(allocationParty);
            }
        }
        for (var seatIndex = 0; seatIndex < totalSeats; seatIndex++) {
            var bestParty = null;
            var bestQuotient = -1;
            for (var eligibleIndex = 0; eligibleIndex < eligibleParties.length; eligibleIndex++) {
                var eligibleParty = eligibleParties[eligibleIndex];
                var quotient = (Number(partyValues[eligibleParty]) || 0)/(allocatedSeats[eligibleParty] + 1);
                if (quotient > bestQuotient) {
                    bestQuotient = quotient;
                    bestParty = eligibleParty;
                }
            }
            if (bestParty === null) {
                break;
            }
            allocatedSeats[bestParty] += 1;
        }
        return allocatedSeats;
