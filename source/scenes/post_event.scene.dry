}
Q.saxony_landtag_seat_count = 96;
Q.saxony_majority_threshold = 49;
if (Q.saxony_landtag_total_seats == undefined) {
    Q.saxony_landtag_total_seats = 96;
}
if (Q.saxony_landtag_seat_allocation_valid == undefined) {
    Q.saxony_landtag_seat_allocation_valid = 1;
}

if (Q.wurttemberg_election_year == undefined) {
    Q.wurttemberg_election_year = 1928;
}
if (Q.wurttemberg_election_month == undefined) {
    Q.wurttemberg_election_month = 5;
}
if (Q.wurttemberg_government == undefined) {
    Q.wurttemberg_government = 4;
}
if (Q.wurttemberg_majority_cabinet == undefined) {
    Q.wurttemberg_majority_cabinet = 1;
}
if (Q.wurttemberg_leader == undefined) {
    Q.wurttemberg_leader = "Eugen Bolz";
}

if (Q.wurttemberg_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.wurttemberg_leverage = 0;
}
if (Q.wurttemberg_snap_election_called == undefined) {
    Q.wurttemberg_snap_election_called = 0;
}
Q.wurttemberg_landtag_seat_count = 80;

if (Q.lubeck_election_month == undefined) {
    Q.lubeck_election_month = 11; // TODO: Confirm exact Lübeck election month cadence.
}
if (Q.lubeck_election_year == undefined) {
    Q.lubeck_election_year = 1927;
}

if (Q.lubeck_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.lubeck_leverage = 0;
}
if (Q.lubeck_government == undefined) {
    Q.lubeck_government = 3;
}
if (Q.lubeck_majority_cabinet == undefined) {
    Q.lubeck_majority_cabinet = 1;
}
if (Q.lubeck_snap_election_called == undefined) {
    Q.lubeck_snap_election_called = 0;
}
Q.lubeck_landtag_seat_count = 80;

if (Q.oldenburg_election_year == undefined) {
    Q.oldenburg_election_year = 1928;
}
if (Q.oldenburg_election_month == undefined) {
    Q.oldenburg_election_month = 5;
}
if (Q.oldenburg_snap_election_called == undefined) {
    Q.oldenburg_snap_election_called = 0;
}
if (Q.oldenburg_government == undefined) {
    Q.oldenburg_government = 0;
}
if (Q.oldenburg_majority_cabinet == undefined) {
    Q.oldenburg_majority_cabinet = 0;
}
if (Q.oldenburg_leader == undefined) {
    Q.oldenburg_leader = "";
}
if (Q.oldenburg_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.oldenburg_leverage = 0;
}
Q.oldenburg_landtag_seat_count = 48;
Q.oldenburg_majority_threshold = 25;
if (Q.oldenburg_landtag_total_seats == undefined) {
    Q.oldenburg_landtag_total_seats = 48;
}
if (Q.oldenburg_landtag_seat_allocation_valid == undefined) {
    Q.oldenburg_landtag_seat_allocation_valid = 1;
}
if (Q.wurttemberg_csvd_party_name == undefined) {
    Q.wurttemberg_csvd_party_name = "Christlich-Sozialer Volksdienst";
}
if (Q.wurttemberg_wbwb_party_name == undefined) {
    Q.wurttemberg_wbwb_party_name = "Württembergischer Bauern- und Weingärtnerbund";
}
if (Q.mecklenburg_schwerin_election_year == undefined) {
    Q.mecklenburg_schwerin_election_year = 1930;
}
if (Q.mecklenburg_schwerin_election_month == undefined) {
    Q.mecklenburg_schwerin_election_month = 6;
}
if (Q.mecklenburg_schwerin_government == undefined) {
    Q.mecklenburg_schwerin_government = 0;
}
if (Q.mecklenburg_schwerin_majority_cabinet == undefined) {
    Q.mecklenburg_schwerin_majority_cabinet = 0;
}
if (Q.mecklenburg_schwerin_leader == undefined) {
    Q.mecklenburg_schwerin_leader = "";
}

if (Q.mecklenburg_schwerin_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.mecklenburg_schwerin_leverage = 0;
}
if (Q.mecklenburg_schwerin_snap_election_called == undefined) {
    Q.mecklenburg_schwerin_snap_election_called = 0;
}
// Mecklenburg-Schwerin baseline: start from June 1926, then apply the 4-year Landtag cycle => June 1930.
Q.mecklenburg_schwerin_landtag_seat_count = 51;
Q.mecklenburg_schwerin_majority_threshold = 26;
if (Q.mecklenburg_schwerin_landtag_total_seats == undefined) {
    Q.mecklenburg_schwerin_landtag_total_seats = 51;
}
if (Q.mecklenburg_schwerin_landtag_seat_allocation_valid == undefined) {
    Q.mecklenburg_schwerin_landtag_seat_allocation_valid = 1;
}
if (Q.mecklenburg_schwerin_parties == undefined) {
    Q.mecklenburg_schwerin_parties = ['spd', 'ddp', 'dvp', 'wp', 'dnvp', 'kpd', 'nsdap', 'z'];
}
for (var mecklenburgSchwerinParty of Q.mecklenburg_schwerin_parties) {
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_raw'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_raw'] = 0; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes'] = 0; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_disp'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_disp'] = '0.0'; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_display'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_votes_display'] = '0.0'; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_result_votes'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_result_votes'] = 0; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_r'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_r'] = 0; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_seats'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_seats'] = 0; }
    if (Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_seat_share_disp'] == undefined) { Q['mecklenburg_schwerin_' + mecklenburgSchwerinParty + '_seat_share_disp'] = '0.0'; }
}
if (Q.mecklenburg_schwerin_current_government_name == undefined) {
    Q.mecklenburg_schwerin_current_government_name = '';
}
if (Q.mecklenburg_schwerin_current_government_parties == undefined) {
    Q.mecklenburg_schwerin_current_government_parties = '';
}
if (Q.mecklenburg_schwerin_current_government_seats == undefined) {
    Q.mecklenburg_schwerin_current_government_seats = 0;
}
if (Q.mecklenburg_schwerin_current_government_status == undefined) {
    Q.mecklenburg_schwerin_current_government_status = 'Minority';
}

for (var relationParty of ['z', 'bvp', 'wp', 'kpd', 'ddp', 'dvp', 'dnvp', 'nsdap']) {
    if (Q[relationParty + '_relation'] == undefined) {
        Q[relationParty + '_relation'] = 50;
    }
    Q[relationParty + '_relation'] = Math.max(0, Math.min(100, Q[relationParty + '_relation']));
}

// Runtime migration/defaults for the DDP congress system.
if (!Q.ddp_factions) {
    Q.ddp_factions = ['ddp_left_progressive', 'ddp_laborist', 'ddp_left_liberal', 'ddp_left_bourgeois', 'ddp_regionalist'];
}
if (!Q.ddp_faction_dissent_variables) {
    Q.ddp_faction_dissent_variables = ['ddp_left_progressive_dissent', 'ddp_laborist_dissent', 'ddp_left_liberal_dissent', 'ddp_left_bourgeois_dissent', 'ddp_regionalist_dissent'];
}
// Keep the canonical DDP variable registry complete when loading saves created before these trackers existed.
Q.ddp_ideology_variables = ['ddp_nationalism_position', 'ddp_economics_position', 'ddp_republic_position', 'ddp_federalism_position', 'ddp_leader', 'ddp_ideology'];
if (!Q.ddp_congress_dates) {
    Q.ddp_congress_dates = ['1925-12', '1927-04', '1929-10', '1931-03', '1933-08'];
}
if (Q.ddp_congress_active === undefined || Q.ddp_congress_active === null) {
    Q.ddp_congress_active = false;
}
if ((Q.ddp_economics_position === undefined || Q.ddp_economics_position === null) && Q.ddp_economic_position !== undefined && Q.ddp_economic_position !== null) {
    Q.ddp_economics_position = Q.ddp_economic_position;
}
var ddpIdeologyDefaults = {
    ddp_nationalism_position: 0,
    ddp_economics_position: 0,
    ddp_republic_position: 0,
    ddp_federalism_position: 0,
    ddp_leader: 0,
    ddp_ideology: 0
};
var ddpIdeologyMax = {
    ddp_nationalism_position: 4,
    ddp_economics_position: 4,
    ddp_republic_position: 2,
    ddp_federalism_position: 3,
    ddp_leader: 6
};
for (var ddpIdeologyVariable of Q.ddp_ideology_variables) {
    if (Q[ddpIdeologyVariable] === undefined || Q[ddpIdeologyVariable] === null || isNaN(Q[ddpIdeologyVariable])) {
        Q[ddpIdeologyVariable] = ddpIdeologyDefaults[ddpIdeologyVariable] || 0;
    }
    Q[ddpIdeologyVariable] = Math.round(Q[ddpIdeologyVariable]);
    if (Q[ddpIdeologyVariable] < 0) {
        Q[ddpIdeologyVariable] = 0;
    }
    if (Q[ddpIdeologyVariable] > ddpIdeologyMax[ddpIdeologyVariable]) {
        Q[ddpIdeologyVariable] = ddpIdeologyMax[ddpIdeologyVariable];
    }
}
for (var ddpDissentVariable of Q.ddp_faction_dissent_variables) {
    if (Q[ddpDissentVariable] === undefined || Q[ddpDissentVariable] === null || isNaN(Q[ddpDissentVariable])) {
        Q[ddpDissentVariable] = 0;
    }
    Q[ddpDissentVariable] = Math.round(Q[ddpDissentVariable]);
    if (Q[ddpDissentVariable] < 0) {
        Q[ddpDissentVariable] = 0;
    }
    if (Q[ddpDissentVariable] > 100) {
        Q[ddpDissentVariable] = 100;
    }
}
var bvpMigrationSupport = {'workers': 0, 'old_middle': 2, 'new_middle': 1, 'rural': 3, 'unemployed': 0, 'catholics': 9};
var wpMigrationSupport = {'workers': 0, 'old_middle': 4, 'new_middle': 4, 'rural': 1, 'unemployed': 0, 'catholics': 2};
for (var migrationClass of Q.classes) {
    if (Q[migrationClass + '_bvp'] == undefined) {
        Q[migrationClass + '_bvp'] = bvpMigrationSupport[migrationClass] || 0;
        if (Q[migrationClass + '_z'] != undefined) {
            Q[migrationClass + '_z'] = Math.max(0, Q[migrationClass + '_z'] - Q[migrationClass + '_bvp']);
        }
    }
    if (Q[migrationClass + '_wp'] == undefined) {
        Q[migrationClass + '_wp'] = wpMigrationSupport[migrationClass] || 0;
        if (Q[migrationClass + '_other'] != undefined) {
            Q[migrationClass + '_other'] = Math.max(0, Q[migrationClass + '_other'] - Q[migrationClass + '_wp']);
        }
    }
}
if (Q.bvp_r == undefined) {
    Q.bvp_r = 3;
    if (Q.z_r != undefined) {
        Q.z_r = Math.max(0, Q.z_r - 3);
    }
}
if (Q.wp_r == undefined) {
    Q.wp_r = 0;
}
if (Q.old_bvp_r == undefined) {
    Q.old_bvp_r = Q.bvp_r;
}
if (Q.old_wp_r == undefined) {
    Q.old_wp_r = Q.wp_r;
}
if (Q.election_records) {
    for (var electionRecord of Q.election_records) {
        if (electionRecord.bvp == undefined) {
            electionRecord.bvp = 0;
        }
        if (electionRecord.wp == undefined) {
            electionRecord.wp = 0;
        }
    }
}
if (Q.party_support_records) {
    for (var supportRecord of Q.party_support_records) {
        if (supportRecord.bvp == undefined) {
            supportRecord.bvp = 0;
        }
        if (supportRecord.wp == undefined) {
            supportRecord.wp = 0;
        }
    }
}

// make sure no stat is below 0.
for (var c of Q.classes) {
    for (var party of Q.parties) {
        if (Q[c+'_'+party] < 0) {
            Q[c+'_'+party] = 0;
        }
    }
}

if (!Q.culture_vars) {
    Q.culture_vars = ['pro_republic', 'pacifism', 'nationalism', 'secularism', 'feminism'];
}
if (!Q.culture_var_registry) {
    Q.culture_var_registry = {
        pro_republic: {min: 0, max: 100, default: 59, description: 'Support for republican/parliamentary constitutional legitimacy.'},
        pacifism: {min: 0, max: 100, default: 50, description: 'Public opposition to militarism and support for diplomatic/non-military solutions.'},
        nationalism: {min: 0, max: 100, default: 60, description: 'Level of nationalist/revanchist political sentiment.'},
        secularism: {min: 0, max: 100, default: 50, description: 'Support for secular public institutions over confessional/religious influence.'},
        feminism: {min: 0, max: 100, default: 50, description: 'Support for women’s political, social, and legal equality.'}
    };
}
if (Q.culture_vars.indexOf('feminism') < 0) {
    Q.culture_vars.push('feminism');
}
if (!Q.culture_var_registry.feminism) {
    Q.culture_var_registry.feminism = {min: 0, max: 100, default: 50, description: 'Support for women’s political, social, and legal equality.'};
}
// Migrate legacy save data from the old SPD-specific pacifism meter to the standardized culture variable.
if (!Q.culture_registry_version && typeof Q.pacifism !== 'number') {
    Q.pacifism = (typeof Q['spd_pacifism'] === 'number') ? 50 + Q['spd_pacifism'] : Q.culture_var_registry.pacifism.default;
}
if (Q['spd_pacifism'] !== undefined) {
    delete Q['spd_pacifism'];
}
Q.pro_republic = Math.round(Q.pro_republic);
Q.nationalism = Math.round(Q.nationalism);
Q.socialism = Math.round(Q.socialism);

if (Q.presidential_anger === undefined || Q.presidential_anger === null || isNaN(Q.presidential_anger)) {
    Q.presidential_anger = 0;
}
Q.presidential_anger = Math.round(Q.presidential_anger);
if (Q.presidential_anger < 0) {
    Q.presidential_anger = 0;
}
if (Q.presidential_anger > 100) {
    Q.presidential_anger = 100;
}

// Maintain simplified faction variables for event effects, conditional checks,
// scripted references, save/load migrations, and debug/state viewers.
// left = moderate/parliamentary tendency.
// right = nationalist/authoritarian or radical tendency depending on party.
if (!Q.simplified_faction_variables) {
    Q.simplified_faction_variables = ['dnvp_left', 'dnvp_right', 'dvp_left', 'dvp_right', 'spd_left', 'spd_right'];
}
if (!Q.simplified_faction_pairs) {
    Q.simplified_faction_pairs = [
        {party: 'dnvp', left: 'dnvp_left', right: 'dnvp_right'},
        {party: 'dvp', left: 'dvp_left', right: 'dvp_right'},
        {party: 'spd', left: 'spd_left', right: 'spd_right'}
    ];
}
for (var faction_variable of Q.simplified_faction_variables) {
    if (Q[faction_variable] === undefined || isNaN(Q[faction_variable])) {
        Q[faction_variable] = 50;
    }
    Q[faction_variable] = Math.round(Q[faction_variable]);
    if (Q[faction_variable] < 0) {
        Q[faction_variable] = 0;
    } else if (Q[faction_variable] > 100) {
        Q[faction_variable] = 100;
    }
}
for (var simplified_pair of Q.simplified_faction_pairs) {
    Q[simplified_pair.party + '_faction_total'] = Q[simplified_pair.left] + Q[simplified_pair.right];
    Q[simplified_pair.party + '_faction_balance'] = Q[simplified_pair.right] - Q[simplified_pair.left];
}
if (!Q.core_state_variables) {
    Q.core_state_variables = [];
}
if (!Q.scripted_event_variables) {
    Q.scripted_event_variables = [];
}
if (!Q.debug_state_variables) {
    Q.debug_state_variables = [];
}
if (!Q.audit_state_variables) {
    Q.audit_state_variables = [];
}
