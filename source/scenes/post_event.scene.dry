        q.bremen_landtag_total_seats = 0;
        for (var bremenSeatParty of bremenParties) {
            q['bremen_' + bremenSeatParty + '_r'] = bremenSeats[bremenSeatParty] || 0;
            q['bremen_' + bremenSeatParty + '_seats'] = q['bremen_' + bremenSeatParty + '_r'];
            q['bremen_' + bremenSeatParty + '_seat_share_disp'] = (Math.round((100*q['bremen_' + bremenSeatParty + '_r']/bremenSeatCount)*10)/10).toFixed(1);
            q.bremen_landtag_total_seats += q['bremen_' + bremenSeatParty + '_r'];
        }
        q.bremen_landtag_seat_allocation_valid = q.bremen_landtag_total_seats == bremenSeatCount ? 1 : 0;
        if (typeof window.updateBremenCoalitionOptions === 'function') {
            window.updateBremenCoalitionOptions(q);
        }
    };
    window.updateBremenCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        q.bremen_landtag_seat_count = 120;
        var threshold = 61;
        if (q.bremen_government == undefined) {
            q.bremen_government = 5;
        }
        var options = [
            {id: 1, key: 'sole_spd', name: 'Sole SPD', parties: 'SPD', seats: (Number(q.bremen_spd_r) || 0)},
            {id: 2, key: 'spd_kpd', name: 'SPD-KPD', parties: 'SPD + KPD', seats: (Number(q.bremen_spd_r) || 0) + (Number(q.bremen_kpd_r) || 0)},
            {id: 3, key: 'spd_ddp', name: 'SPD-DDP', parties: 'SPD + DDP', seats: (Number(q.bremen_spd_r) || 0) + (Number(q.bremen_ddp_r) || 0)},
            {id: 4, key: 'spd_ddp_dvp', name: 'SPD-DDP-DVP', parties: 'SPD + DDP + DVP', seats: (Number(q.bremen_spd_r) || 0) + (Number(q.bremen_ddp_r) || 0) + (Number(q.bremen_dvp_r) || 0)},
            {id: 5, key: 'dvp_dnvp_ddp_hausbesitzer', name: 'DVP-DNVP-DDP-Hausbesitzer', parties: 'DVP + DNVP + DDP + Hausbesitzer', seats: (Number(q.bremen_dvp_r) || 0) + (Number(q.bremen_dnvp_r) || 0) + (Number(q.bremen_ddp_r) || 0) + (Number(q.bremen_hausbesitzer_r) || 0)}
        ];
        q.bremen_majority_threshold = threshold;
        var anyMajority = 0;
        for (var majorityIndex = 0; majorityIndex < options.length; majorityIndex++) {
            if (options[majorityIndex].seats >= threshold) {
                anyMajority = 1;
            }
        }
        q.bremen_any_majority_coalition = anyMajority;
        for (var optionIndex = 0; optionIndex < options.length; optionIndex++) {
            var option = options[optionIndex];
            var prefix = 'bremen_' + option.key + '_coalition';
            var hasMajority = option.seats >= threshold;
            var isIncumbent = Number(q.bremen_government) === option.id;
            q[prefix + '_name'] = option.name;
            q[prefix + '_parties'] = option.parties;
            q[prefix + '_seats'] = option.seats;
            q[prefix + '_majority'] = hasMajority ? 1 : 0;
            q[prefix + '_status'] = hasMajority ? 'Majority' : 'Minority';
            q[prefix + '_selectable'] = hasMajority || (!anyMajority && isIncumbent) ? 1 : 0;
        }
        var selected = options[(Number(q.bremen_government) || 5) - 1] || options[4];
        q.bremen_current_government_name = selected.name;
        q.bremen_current_government_parties = selected.parties;
        q.bremen_current_government_seats = selected.seats;
        q.bremen_majority_cabinet = selected.seats >= threshold ? 1 : 0;
        q.bremen_current_government_status = q.bremen_majority_cabinet ? 'Majority' : 'Minority';
    };
    window.calculateBremenLandtagResults(Q);

    // Calculate Hamburg Bürgerschaft/Landtag support from federal party support using Hamburg party weights.
    window.calculateHamburgLandtagResults = function(qualities) {
        var q = qualities || Q;
        var hamburgParties = ['spd', 'kpd', 'ddp', 'dvp', 'dnvp', 'z', 'nsdap', 'wp'];
        q.hamburg_parties = hamburgParties;
        var hamburgSeatCount = 160;
        q.hamburg_landtag_seat_count = 160;
        var hamburgWeights = {
            spd: 1.27,
            kpd: 1.45,
            ddp: 3.00,
            dvp: 1.40,
            dnvp: 0.86,
            z: 0.11,
            nsdap: 0.80,
            wp: 0.62
        };
        q.hamburg_party_weights = hamburgWeights;
        function federalShare(party) {
            var share = Number(q[party + '_votes_raw']);
            if (isNaN(share)) {
                share = 100*(Number(q[party + '_normalized']) || 0);
            }
            if (isNaN(share) || share < 0) {
                share = 0;
            }
            return share;
        }
        var weightedVotes = {};
        var weightedTotal = 0;
        for (var hamburgWeightedParty of hamburgParties) {
            weightedVotes[hamburgWeightedParty] = federalShare(hamburgWeightedParty)*(hamburgWeights[hamburgWeightedParty] || 1.00);
            weightedTotal += weightedVotes[hamburgWeightedParty] || 0;
        }
        var hamburgVoteShares = {};
        for (var hamburgShareParty of hamburgParties) {
            var hamburgRawShare = weightedTotal > 0 ? 100*(weightedVotes[hamburgShareParty] || 0)/weightedTotal : 0;
            q['hamburg_' + hamburgShareParty + '_votes_raw'] = hamburgRawShare;
            q['hamburg_' + hamburgShareParty + '_votes'] = Math.round(hamburgRawShare*10)/10;
            q['hamburg_' + hamburgShareParty + '_votes_disp'] = q['hamburg_' + hamburgShareParty + '_votes'].toFixed(1);
            q['hamburg_' + hamburgShareParty + '_votes_display'] = q['hamburg_' + hamburgShareParty + '_votes_disp'];
            q['hamburg_' + hamburgShareParty + '_result_votes'] = q['hamburg_' + hamburgShareParty + '_votes'];
            hamburgVoteShares[hamburgShareParty] = q['hamburg_' + hamburgShareParty + '_votes'];
        }
        var hamburgBannedParties = {};
        for (var hamburgBannedParty of hamburgParties) {
            hamburgBannedParties[hamburgBannedParty] = q[hamburgBannedParty + '_banned'];
        }
        var hamburgThreshold = q.hamburg_electoral_threshold || q.electoral_threshold || 0;
        var hamburgSeats = window.allocateDhondtSeats(hamburgVoteShares, hamburgSeatCount, hamburgThreshold, {parties: hamburgParties, banned: hamburgBannedParties});
        q.hamburg_landtag_total_seats = 0;
        for (var hamburgSeatParty of hamburgParties) {
            q['hamburg_' + hamburgSeatParty + '_r'] = hamburgSeats[hamburgSeatParty] || 0;
            q['hamburg_' + hamburgSeatParty + '_seats'] = q['hamburg_' + hamburgSeatParty + '_r'];
            q['hamburg_' + hamburgSeatParty + '_seat_share_disp'] = (Math.round((100*q['hamburg_' + hamburgSeatParty + '_r']/hamburgSeatCount)*10)/10).toFixed(1);
            q.hamburg_landtag_total_seats += q['hamburg_' + hamburgSeatParty + '_r'];
        }
        q.hamburg_landtag_seat_allocation_valid = q.hamburg_landtag_total_seats == hamburgSeatCount ? 1 : 0;
        if (typeof window.updateHamburgCoalitionOptions === 'function') {
            window.updateHamburgCoalitionOptions(q);
        }
    };
    window.updateHamburgCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        q.hamburg_landtag_seat_count = 160;
        var threshold = 81;
        if (q.hamburg_government == undefined) {
            q.hamburg_government = 3;
        }
        var options = [
            {id: 1, key: 'spd_kpd', name: 'SPD-KPD', parties: 'SPD + KPD', seats: (Number(q.hamburg_spd_r) || 0) + (Number(q.hamburg_kpd_r) || 0)},
            {id: 2, key: 'sole_spd', name: 'Sole SPD', parties: 'SPD', seats: (Number(q.hamburg_spd_r) || 0)},
            {id: 3, key: 'spd_ddp', name: 'SPD-DDP', parties: 'SPD + DDP', seats: (Number(q.hamburg_spd_r) || 0) + (Number(q.hamburg_ddp_r) || 0)},
            {id: 4, key: 'spd_ddp_dvp', name: 'SPD-DDP-DVP', parties: 'SPD + DDP + DVP', seats: (Number(q.hamburg_spd_r) || 0) + (Number(q.hamburg_ddp_r) || 0) + (Number(q.hamburg_dvp_r) || 0)},
            {id: 5, key: 'ddp_dnvp_wp_dvp', name: 'DDP-DNVP-WP-DVP', parties: 'DDP + DNVP + WP + DVP', seats: (Number(q.hamburg_ddp_r) || 0) + (Number(q.hamburg_dnvp_r) || 0) + (Number(q.hamburg_wp_r) || 0) + (Number(q.hamburg_dvp_r) || 0)}
        ];
        q.hamburg_majority_threshold = threshold;
        var anyMajority = 0;
        for (var majorityIndex = 0; majorityIndex < options.length; majorityIndex++) {
            if (options[majorityIndex].seats >= threshold) {
                anyMajority = 1;
            }
        }
        q.hamburg_any_majority_coalition = anyMajority;
        for (var optionIndex = 0; optionIndex < options.length; optionIndex++) {
            var option = options[optionIndex];
            var prefix = 'hamburg_' + option.key + '_coalition';
            var hasMajority = option.seats >= threshold;
            var isIncumbent = Number(q.hamburg_government) === option.id;
            q[prefix + '_name'] = option.name;
            q[prefix + '_parties'] = option.parties;
            q[prefix + '_seats'] = option.seats;
            q[prefix + '_majority'] = hasMajority ? 1 : 0;
            q[prefix + '_status'] = hasMajority ? 'Majority' : 'Minority';
            q[prefix + '_selectable'] = hasMajority || (!anyMajority && isIncumbent) ? 1 : 0;
        }
        var selected = options[(Number(q.hamburg_government) || 3) - 1] || options[2];
        q.hamburg_current_government_name = selected.name;
        q.hamburg_current_government_parties = selected.parties;
        q.hamburg_current_government_seats = selected.seats;
        q.hamburg_majority_cabinet = selected.seats >= threshold ? 1 : 0;
        q.hamburg_current_government_status = q.hamburg_majority_cabinet ? 'Majority' : 'Minority';
        q.hamburg_leader_default = selected.parties.indexOf('SPD') >= 0 ? 'Rudolf Ross' : (selected.parties.indexOf('DDP') >= 0 ? 'Carl Wilhelm Petersen' : (selected.parties.indexOf('DVP') >= 0 ? 'Walther Dauch' : ''));
    };
    window.calculateHamburgLandtagResults(Q);

    // Calculate Saxony Landtag support from federal party support using Saxony party weights.
    // Saxony has a state-only ASPD split from the weighted SPD pool.
    window.calculateSaxonyLandtagResults = function(qualities) {
        var q = qualities || Q;
        var saxonyParties = ['spd', 'kpd', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'aspd', 'other'];
        q.saxony_parties = saxonyParties;
        q.saxony_aspd_party_name = 'Alte Sozialdemokratische Partei Deutschlands';
        var saxonySeatCount = 96;
        q.saxony_landtag_seat_count = 96;
        var saxonyWeights = {
            spd: 1.50,
            kpd: 1.40,
            wp: 3.10,
            dvp: 1.90,
            nsdap: 0.55,
            dnvp: 0.72,
            ddp: 0.55,
            other: 1.00
        };
        q.saxony_party_weights = saxonyWeights;
        function federalShare(party) {
            var share = Number(q[party + '_votes_raw']);
            if (isNaN(share)) {
                share = 100*(Number(q[party + '_normalized']) || 0);
            }
            if (isNaN(share) || share < 0) {
                share = 0;
            }
            return share;
        }
        var weightedSpdPool = federalShare('spd')*saxonyWeights.spd;
        var aspdSplitShare = 0.05;
        q.saxony_spd_pool_weighted_raw = weightedSpdPool;
        q.saxony_spd_split_aspd_share = aspdSplitShare;
        q.saxony_spd_split_spd_share = 1 - aspdSplitShare;
        var weightedVotes = {
            spd: weightedSpdPool*(1 - aspdSplitShare),
            aspd: weightedSpdPool*aspdSplitShare,
            kpd: federalShare('kpd')*saxonyWeights.kpd,
            ddp: federalShare('ddp')*saxonyWeights.ddp,
            dvp: federalShare('dvp')*saxonyWeights.dvp,
            wp: federalShare('wp')*saxonyWeights.wp,
            dnvp: federalShare('dnvp')*saxonyWeights.dnvp,
            nsdap: federalShare('nsdap')*saxonyWeights.nsdap,
            other: federalShare('other')*saxonyWeights.other
        };
        var weightedTotal = 0;
        for (var saxonyWeightedParty of saxonyParties) {
            weightedTotal += weightedVotes[saxonyWeightedParty] || 0;
        }
        var saxonyVoteShares = {};
        for (var saxonyShareParty of saxonyParties) {
            var saxonyRawShare = weightedTotal > 0 ? 100*(weightedVotes[saxonyShareParty] || 0)/weightedTotal : 0;
            q['saxony_' + saxonyShareParty + '_votes_raw'] = saxonyRawShare;
            q['saxony_' + saxonyShareParty + '_votes'] = Math.round(saxonyRawShare*10)/10;
            q['saxony_' + saxonyShareParty + '_votes_disp'] = q['saxony_' + saxonyShareParty + '_votes'].toFixed(1);
            q['saxony_' + saxonyShareParty + '_votes_display'] = q['saxony_' + saxonyShareParty + '_votes_disp'];
            q['saxony_' + saxonyShareParty + '_result_votes'] = q['saxony_' + saxonyShareParty + '_votes'];
            saxonyVoteShares[saxonyShareParty] = q['saxony_' + saxonyShareParty + '_votes'];
        }
        var saxonyBannedParties = {};
        for (var saxonyBannedParty of saxonyParties) {
            saxonyBannedParties[saxonyBannedParty] = q[saxonyBannedParty + '_banned'];
        }
        var saxonyThreshold = q.saxony_electoral_threshold || q.electoral_threshold || 0;
        var saxonySeats = window.allocateDhondtSeats(saxonyVoteShares, saxonySeatCount, saxonyThreshold, {parties: saxonyParties, banned: saxonyBannedParties});
        q.saxony_landtag_total_seats = 0;
        for (var saxonySeatParty of saxonyParties) {
            q['saxony_' + saxonySeatParty + '_r'] = saxonySeats[saxonySeatParty] || 0;
            q['saxony_' + saxonySeatParty + '_seats'] = q['saxony_' + saxonySeatParty + '_r'];
            q['saxony_' + saxonySeatParty + '_seat_share_disp'] = (Math.round((100*q['saxony_' + saxonySeatParty + '_r']/saxonySeatCount)*10)/10).toFixed(1);
            q.saxony_landtag_total_seats += q['saxony_' + saxonySeatParty + '_r'];
        }
        q.saxony_landtag_seat_allocation_valid = q.saxony_landtag_total_seats == saxonySeatCount ? 1 : 0;
    };
    window.calculateSaxonyLandtagResults(Q);

    
    window.calculateWurttembergLandtagResults = function(qualities) {
        var q = qualities || Q;
        var wurttembergParties = ['spd', 'ddp', 'dvp', 'z', 'kpd', 'dnvp', 'csvd', 'wbwb', 'nsdap', 'other'];
        q.wurttemberg_parties = wurttembergParties;
        var seatCount = 80;
        q.wurttemberg_landtag_seat_count = 80;
        var wurttembergWeights = {z: 1.64, ddp: 1.90, dvp: 0.63, spd: 0.77, kpd: 0.67, nsdap: 0.71, dnvp: 2.14, other: 1.00};
        q.wurttemberg_party_weights = wurttembergWeights;
        function federalShare(party) {
            var share = Number(q[party + '_votes_raw']);
            if (isNaN(share)) { share = 100*(Number(q[party + '_normalized']) || 0); }
            if (isNaN(share) || share < 0) { share = 0; }
            return share;
        }
        var weightedDnvpPool = federalShare('dnvp')*wurttembergWeights.dnvp;
        q.wurttemberg_dnvp_pool_weighted_raw = weightedDnvpPool;
        q.wurttemberg_dnvp_split_csvd_share = 1/6;
        q.wurttemberg_dnvp_split_wbwb_share = 4/6;
        q.wurttemberg_dnvp_split_dnvp_share = 1/6;
        var weightedVotes = {
            spd: federalShare('spd')*wurttembergWeights.spd,
            ddp: federalShare('ddp')*wurttembergWeights.ddp,
            dvp: federalShare('dvp')*wurttembergWeights.dvp,
            z: federalShare('z')*wurttembergWeights.z,
            kpd: federalShare('kpd')*wurttembergWeights.kpd,
            dnvp: weightedDnvpPool*(1/6),
            csvd: weightedDnvpPool*(1/6),
            wbwb: weightedDnvpPool*(4/6),
            nsdap: federalShare('nsdap')*wurttembergWeights.nsdap,
            other: federalShare('other')*wurttembergWeights.other
        };
        var total = 0;
        for (var pty of wurttembergParties) { total += weightedVotes[pty] || 0; }
        var voteShares = {};
        for (var party of wurttembergParties) {
            var raw = total > 0 ? 100*(weightedVotes[party] || 0)/total : 0;
            q['wurttemberg_' + party + '_votes_raw'] = raw;
            q['wurttemberg_' + party + '_votes'] = Math.round(raw*10)/10;
            q['wurttemberg_' + party + '_votes_disp'] = q['wurttemberg_' + party + '_votes'].toFixed(1);
            q['wurttemberg_' + party + '_result_votes'] = q['wurttemberg_' + party + '_votes'];
            voteShares[party] = q['wurttemberg_' + party + '_votes'];
        }
        var banned = {};
        for (var bannedParty of wurttembergParties) { banned[bannedParty] = q[bannedParty + '_banned']; }
        var threshold = q.wurttemberg_electoral_threshold || q.electoral_threshold || 0;
        var seats = window.allocateDhondtSeats(voteShares, seatCount, threshold, {parties: wurttembergParties, banned: banned});
        q.wurttemberg_landtag_total_seats = 0;
        for (var seatParty of wurttembergParties) {
            q['wurttemberg_' + seatParty + '_r'] = seats[seatParty] || 0;
            q['wurttemberg_' + seatParty + '_seats'] = q['wurttemberg_' + seatParty + '_r'];
            q.wurttemberg_landtag_total_seats += q['wurttemberg_' + seatParty + '_r'];
        }
        q.wurttemberg_landtag_seat_allocation_valid = q.wurttemberg_landtag_total_seats == seatCount ? 1 : 0;
        if (typeof window.updateWurttembergCoalitionOptions === 'function') { window.updateWurttembergCoalitionOptions(q); }
    };
    window.updateWurttembergCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        var threshold = 41;
        if (q.wurttemberg_government == undefined) { q.wurttemberg_government = 4; }
        var options = [
            {id:1,key:'spd_ddp',name:'SPD-DDP',parties:'SPD + DDP',seats:(Number(q.wurttemberg_spd_r)||0)+(Number(q.wurttemberg_ddp_r)||0)},
            {id:2,key:'spd_ddp_dvp',name:'SPD-DDP-DVP',parties:'SPD + DDP + DVP',seats:(Number(q.wurttemberg_spd_r)||0)+(Number(q.wurttemberg_ddp_r)||0)+(Number(q.wurttemberg_dvp_r)||0)},
            {id:3,key:'spd_ddp_z_dvp',name:'SPD-DDP-Z-DVP',parties:'SPD + DDP + Z + DVP',seats:(Number(q.wurttemberg_spd_r)||0)+(Number(q.wurttemberg_ddp_r)||0)+(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_dvp_r)||0)},
            {id:4,key:'ddp_z_dvp',name:'DDP-Z-DVP',parties:'DDP + Z + DVP',seats:(Number(q.wurttemberg_ddp_r)||0)+(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_dvp_r)||0)},
            {id:5,key:'ddp_z_dvp_wbwb',name:'DDP-Z-DVP-WBWB',parties:'DDP + Z + DVP + WBWB',seats:(Number(q.wurttemberg_ddp_r)||0)+(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_dvp_r)||0)+(Number(q.wurttemberg_wbwb_r)||0)},
            {id:6,key:'z_dvp_wbwb_dnvp',name:'Z-DVP-WBWB-DNVP',parties:'Z + DVP + WBWB + DNVP',seats:(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_dvp_r)||0)+(Number(q.wurttemberg_wbwb_r)||0)+(Number(q.wurttemberg_dnvp_r)||0)},
            {id:7,key:'z_wbwb_dnvp',name:'Z-WBWB-DNVP',parties:'Z + WBWB + DNVP',seats:(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_wbwb_r)||0)+(Number(q.wurttemberg_dnvp_r)||0)},
            {id:8,key:'z_wbwb_dnvp_csvd',name:'Z-WBWB-DNVP-CSVD',parties:'Z + WBWB + DNVP + CSVD',seats:(Number(q.wurttemberg_z_r)||0)+(Number(q.wurttemberg_wbwb_r)||0)+(Number(q.wurttemberg_dnvp_r)||0)+(Number(q.wurttemberg_csvd_r)||0)},
            {id:9,key:'wbwb_dnvp_nsdap',name:'WBWB-DNVP-NSDAP',parties:'WBWB + DNVP + NSDAP',seats:(Number(q.wurttemberg_wbwb_r)||0)+(Number(q.wurttemberg_dnvp_r)||0)+(Number(q.wurttemberg_nsdap_r)||0)}
        ];
        var anyMajority=0;
        for (var i=0;i<options.length;i++) { if (options[i].seats >= threshold) { anyMajority=1; } }
        for (var j=0;j<options.length;j++) {
            var option=options[j], prefix='wurttemberg_'+option.key+'_coalition', hasMajority=option.seats>=threshold, isIncumbent=Number(q.wurttemberg_government)===option.id;
            q[prefix + '_seats']=option.seats; q[prefix + '_status']=hasMajority?'Majority':'Minority'; q[prefix + '_selectable']=hasMajority || (!anyMajority && isIncumbent) ? 1 : 0;
        }
        var selected = options[(Number(q.wurttemberg_government)||4)-1] || options[3];
        q.wurttemberg_current_government_name = selected.name; q.wurttemberg_current_government_parties = selected.parties; q.wurttemberg_current_government_seats = selected.seats;
        q.wurttemberg_majority_cabinet = selected.seats >= threshold ? 1 : 0; q.wurttemberg_current_government_status = q.wurttemberg_majority_cabinet ? 'Majority' : 'Minority';
        q.wurttemberg_spd_in_government = selected.parties.indexOf('SPD') >= 0 ? 1 : 0;
        q.wurttemberg_ddp_in_government = selected.parties.indexOf('DDP') >= 0 ? 1 : 0;
        q.wurttemberg_z_in_government = selected.parties.indexOf('Z') >= 0 ? 1 : 0;
        q.wurttemberg_dnvp_in_government = selected.parties.indexOf('DNVP') >= 0 ? 1 : 0;
        q.wurttemberg_nsdap_in_government = selected.parties.indexOf('NSDAP') >= 0 ? 1 : 0;
    };
    window.calculateWurttembergLandtagResults(Q);

    window.calculateLubeckLandtagResults = function(qualities) {
        var q = qualities || Q;
        var parties = ['spd', 'kpd', 'ddp', 'dvp', 'dnvp', 'nsdap', 'hvb', 'z', 'other'];
        q.lubeck_parties = parties;
        var seatCount = 80;
        q.lubeck_landtag_seat_count = seatCount;
        var weights = {spd: 1.67, kpd: 0.80, nsdap: 0.78, dnvp: 0.65, dvp: 0.52, ddp: 0.32, hvb: 6.00, z: 0, other: 1.00};
        q.lubeck_party_weights = weights;
        q.lubeck_hvb_name = 'Hanseatischer Volksbund';
        function fed(party) {
            var share = Number(q[party + '_votes_raw']);
            if (isNaN(share)) { share = 100*(Number(q[party + '_normalized']) || 0); }
            return isNaN(share) || share < 0 ? 0 : share;
        }
        var weightedVotes = {
            spd: fed('spd')*weights.spd,
            kpd: fed('kpd')*weights.kpd,
            ddp: fed('ddp')*weights.ddp,
            dvp: fed('dvp')*weights.dvp,
            dnvp: fed('dnvp')*weights.dnvp,
            nsdap: fed('nsdap')*weights.nsdap,
            hvb: fed('other')*weights.hvb,
            z: 0,
            other: fed('other')*weights.other
        };
        var total = 0;
        for (var pty of parties) { total += weightedVotes[pty] || 0; }
        var voteShares = {};
        for (var party of parties) {
            var raw = total > 0 ? 100*(weightedVotes[party] || 0)/total : 0;
            q['lubeck_' + party + '_votes_raw'] = raw;
            q['lubeck_' + party + '_votes'] = Math.round(raw*10)/10;
            q['lubeck_' + party + '_votes_disp'] = q['lubeck_' + party + '_votes'].toFixed(1);
            q['lubeck_' + party + '_result_votes'] = q['lubeck_' + party + '_votes'];
            voteShares[party] = q['lubeck_' + party + '_votes'];
        }
        var banned = {};
        for (var b of parties) { banned[b] = q[b + '_banned']; }
        banned.z = 1;
        var threshold = q.lubeck_electoral_threshold || q.electoral_threshold || 0;
        var seats = window.allocateDhondtSeats(voteShares, seatCount, threshold, {parties: parties, banned: banned});
        q.lubeck_landtag_total_seats = 0;
        for (var seatParty of parties) {
            q['lubeck_' + seatParty + '_r'] = seats[seatParty] || 0;
            q['lubeck_' + seatParty + '_seats'] = q['lubeck_' + seatParty + '_r'];
            q.lubeck_landtag_total_seats += q['lubeck_' + seatParty + '_r'];
        }
        q.lubeck_z_votes_raw = 0; q.lubeck_z_votes = 0; q.lubeck_z_votes_disp = '0.0'; q.lubeck_z_r = 0; q.lubeck_z_seats = 0;
        q.lubeck_landtag_seat_allocation_valid = q.lubeck_landtag_total_seats == seatCount ? 1 : 0;
        if (typeof window.updateLubeckCoalitionOptions === 'function') { window.updateLubeckCoalitionOptions(q); }
    };
    window.updateLubeckCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        var threshold = 41;
        if (q.lubeck_government == undefined) { q.lubeck_government = 3; }
        var options = [
            {id:1,key:'spd_ddp',name:'SPD-DDP',parties:'SPD + DDP',seats:(Number(q.lubeck_spd_r)||0)+(Number(q.lubeck_ddp_r)||0)},
            {id:2,key:'spd_ddp_dvp',name:'SPD-DDP-DVP',parties:'SPD + DDP + DVP',seats:(Number(q.lubeck_spd_r)||0)+(Number(q.lubeck_ddp_r)||0)+(Number(q.lubeck_dvp_r)||0)},
            {id:3,key:'ddp_dvp_hvb',name:'DDP-DVP-HVB',parties:'DDP + DVP + HVB',seats:(Number(q.lubeck_ddp_r)||0)+(Number(q.lubeck_dvp_r)||0)+(Number(q.lubeck_hvb_r)||0)},
            {id:4,key:'ddp_dvp_dnvp_hvb',name:'DDP-DVP-DNVP-HVB',parties:'DDP + DVP + DNVP + HVB',seats:(Number(q.lubeck_ddp_r)||0)+(Number(q.lubeck_dvp_r)||0)+(Number(q.lubeck_dnvp_r)||0)+(Number(q.lubeck_hvb_r)||0)},
            {id:5,key:'dvp_dnvp_nsdap',name:'DVP-DNVP-NSDAP',parties:'DVP + DNVP + NSDAP',seats:(Number(q.lubeck_dvp_r)||0)+(Number(q.lubeck_dnvp_r)||0)+(Number(q.lubeck_nsdap_r)||0)}
        ];
        var anyMajority = 0;
        for (var i=0;i<options.length;i++) { if (options[i].seats >= threshold) { anyMajority = 1; } }
        for (var j=0;j<options.length;j++) {
            var option = options[j], prefix = 'lubeck_' + option.key + '_coalition', hasMajority = option.seats >= threshold, isIncumbent = Number(q.lubeck_government) === option.id;
            q[prefix + '_seats'] = option.seats; q[prefix + '_status'] = hasMajority ? 'Majority' : 'Minority'; q[prefix + '_selectable'] = hasMajority || (!anyMajority && isIncumbent) ? 1 : 0;
        }
        var selected = options[(Number(q.lubeck_government) || 3) - 1] || options[2];
        q.lubeck_current_government_name = selected.name; q.lubeck_current_government_parties = selected.parties; q.lubeck_current_government_seats = selected.seats;
        q.lubeck_majority_cabinet = selected.seats >= threshold ? 1 : 0; q.lubeck_current_government_status = q.lubeck_majority_cabinet ? 'Majority' : 'Minority';
        q.lubeck_spd_in_government = selected.parties.indexOf('SPD') >= 0 ? 1 : 0;
        q.lubeck_ddp_in_government = selected.parties.indexOf('DDP') >= 0 ? 1 : 0;
        q.lubeck_dvp_in_government = selected.parties.indexOf('DVP') >= 0 ? 1 : 0;
        q.lubeck_hvb_in_government = selected.parties.indexOf('HVB') >= 0 ? 1 : 0;
        q.lubeck_nsdap_in_government = selected.parties.indexOf('NSDAP') >= 0 ? 1 : 0;
        var currentYear = Number(q.year) || 0;
        q.lubeck_leader_default = q.lubeck_nsdap_in_government ? 'Otto-Heinrich Drechsler' : (q.lubeck_spd_in_government ? 'Paul Löwigt' : (q.lubeck_hvb_in_government ? (currentYear >= 1928 ? 'Rudolf Keibel' : 'Johann Martin Andreas Neumann') : (q.lubeck_dvp_in_government ? (q.lubeck_spd_in_government ? 'Carl Heinsohn' : 'Hans Ewers') : (q.lubeck_ddp_in_government ? 'Heinrich Eckholdt' : ''))));
    };
    window.calculateLubeckLandtagResults(Q);

    window.calculateOldenburgLandtagResults = function(qualities) {
        var q = qualities || Q;
        var oldenburgParties = ['spd', 'z', 'ddp', 'dvp', 'wp', 'dnvp', 'cnbl', 'kpd', 'nsdap', 'other'];
        q.oldenburg_parties = oldenburgParties;
        var oldenburgSeatCount = 48;
        q.oldenburg_landtag_seat_count = oldenburgSeatCount;
        var oldenburgWeights = {z: 1.60, ddp: 2.55, dvp: 2.17, spd: 0.89, kpd: 0.56, dnvp: 1.12, nsdap: 1.80, wp: 0.73, other: 1.00};
        q.oldenburg_party_weights = oldenburgWeights;
        q.oldenburg_cnbl_name = 'Christlich-Nationale Bauern- und Landvolkpartei';
        function fed(party) {
            var share = Number(q[party + '_votes_raw']);
            if (isNaN(share)) { share = 100*(Number(q[party + '_normalized']) || 0); }
            return isNaN(share) || share < 0 ? 0 : share;
        }
        var weightedVotes = {
            spd: fed('spd')*0.89,
            z: fed('z')*1.60,
            ddp: fed('ddp')*2.55,
            dvp: fed('dvp')*2.17,
            wp: fed('wp')*0.73,
            kpd: fed('kpd')*0.56,
            nsdap: fed('nsdap')*1.80,
            other: fed('other')*1.00
        };
        var dnvpPool = fed('dnvp')*1.12;
        weightedVotes.cnbl = dnvpPool*0.25;
        weightedVotes.dnvp = dnvpPool*0.75;
        var weightedTotal = 0;
        for (var pty of oldenburgParties) { weightedTotal += weightedVotes[pty] || 0; }
        var oldenburgVoteShares = {};
        for (var party of oldenburgParties) {
            var rawShare = weightedTotal > 0 ? 100*(weightedVotes[party] || 0)/weightedTotal : 0;
            q['oldenburg_' + party + '_votes_raw'] = rawShare;
            q['oldenburg_' + party + '_votes'] = Math.round(rawShare*10)/10;
            q['oldenburg_' + party + '_votes_disp'] = q['oldenburg_' + party + '_votes'].toFixed(1);
            q['oldenburg_' + party + '_votes_display'] = q['oldenburg_' + party + '_votes_disp'];
            q['oldenburg_' + party + '_result_votes'] = q['oldenburg_' + party + '_votes'];
            oldenburgVoteShares[party] = q['oldenburg_' + party + '_votes'];
        }
        var banned = {};
        for (var bannedParty of oldenburgParties) { banned[bannedParty] = q[bannedParty + '_banned']; }
        var threshold = q.oldenburg_electoral_threshold || q.electoral_threshold || 0;
        var seats = window.allocateDhondtSeats(oldenburgVoteShares, oldenburgSeatCount, threshold, {parties: oldenburgParties, banned: banned});
        q.oldenburg_landtag_total_seats = 0;
        for (var seatParty of oldenburgParties) {
            q['oldenburg_' + seatParty + '_r'] = seats[seatParty] || 0;
            q['oldenburg_' + seatParty + '_seats'] = q['oldenburg_' + seatParty + '_r'];
            q['oldenburg_' + seatParty + '_seat_share_disp'] = (Math.round((100*q['oldenburg_' + seatParty + '_r']/oldenburgSeatCount)*10)/10).toFixed(1);
            q.oldenburg_landtag_total_seats += q['oldenburg_' + seatParty + '_r'];
        }
        q.oldenburg_landtag_seat_allocation_valid = q.oldenburg_landtag_total_seats == oldenburgSeatCount ? 1 : 0;
        if (typeof window.updateOldenburgCoalitionOptions === 'function') { window.updateOldenburgCoalitionOptions(q); }
    };
    window.updateOldenburgCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        var threshold = 25;
        var seatCount = 48;
        q.oldenburg_landtag_seat_count = seatCount;
        q.oldenburg_majority_threshold = threshold;
        if (q.oldenburg_government == undefined) { q.oldenburg_government = 3; }

        var before1930 = Number(q.year) < 1930;
        var options = [
            {id:1,key:'technocratic',name:'Technocratic',parties:'None',seats:0,technocratic:true},
            {id:2,key:'spd_z_ddp',name:'SPD-Z-DDP',parties:'SPD + Z + DDP',seats:(Number(q.oldenburg_spd_r)||0)+(Number(q.oldenburg_z_r)||0)+(Number(q.oldenburg_ddp_r)||0)},
            {id:3,key:'z_ddp_dvp',name:'Z-DDP-DVP',parties:'Z + DDP + DVP',seats:(Number(q.oldenburg_z_r)||0)+(Number(q.oldenburg_ddp_r)||0)+(Number(q.oldenburg_dvp_r)||0)},
            {id:4,key:'ddp_dvp_wp',name:'DDP-DVP-WP',parties:'DDP + DVP + WP',seats:(Number(q.oldenburg_ddp_r)||0)+(Number(q.oldenburg_dvp_r)||0)+(Number(q.oldenburg_wp_r)||0)},
            {id:5,key:'ddp_dnvp_z_dvp',name:'DDP-DNVP-Z-DVP',parties:'DDP + DNVP + Z + DVP',seats:(Number(q.oldenburg_ddp_r)||0)+(Number(q.oldenburg_dnvp_r)||0)+(Number(q.oldenburg_z_r)||0)+(Number(q.oldenburg_dvp_r)||0)},
            {id:6,key:'dnvp_z_dvp_cnbl',name:'DNVP-Z-DVP-CNBL',parties:'DNVP + Z + DVP + CNBL',seats:(Number(q.oldenburg_dnvp_r)||0)+(Number(q.oldenburg_z_r)||0)+(Number(q.oldenburg_dvp_r)||0)+(Number(q.oldenburg_cnbl_r)||0)},
            {id:7,key:'nsdap_dnvp',name:'NSDAP-DNVP',parties:'NSDAP + DNVP',seats:(Number(q.oldenburg_nsdap_r)||0)+(Number(q.oldenburg_dnvp_r)||0)},
            {id:8,key:'nsdap_majority',name:'NSDAP Majority',parties:'NSDAP',seats:(Number(q.oldenburg_nsdap_r)||0)}
        ];

        var anyMajority = 0;
        for (var i = 0; i < options.length; i++) {
            if (!options[i].technocratic && options[i].seats >= threshold) { anyMajority = 1; }
        }

        for (var j = 0; j < options.length; j++) {
            var option = options[j];
            var prefix = 'oldenburg_' + option.key + '_coalition';
            var hasMajority = option.seats >= threshold;
            var technocraticSelectable = option.technocratic && before1930;
            var incumbentFallback = !anyMajority && Number(q.oldenburg_government) === option.id;
            q[prefix + '_name'] = option.name;
            q[prefix + '_parties'] = option.parties;
            q[prefix + '_seats'] = option.seats;
            q[prefix + '_majority'] = hasMajority ? 1 : 0;
            q[prefix + '_status'] = hasMajority ? 'Majority' : 'Minority';
            q[prefix + '_selectable'] = (hasMajority || technocraticSelectable || incumbentFallback) ? 1 : 0;
        }

        var selected = options[(Number(q.oldenburg_government) || 3) - 1] || options[2];
        q.oldenburg_current_government_name = selected.name;
        q.oldenburg_current_government_parties = selected.parties;
        q.oldenburg_current_government_seats = selected.seats;
        q.oldenburg_majority_cabinet = selected.seats >= threshold ? 1 : 0;
        q.oldenburg_current_government_status = q.oldenburg_majority_cabinet ? 'Majority' : 'Minority';

        var parties = selected.parties;
        q.oldenburg_spd_in_government = parties.indexOf('SPD') >= 0 ? 1 : 0;
        q.oldenburg_ddp_in_government = parties.indexOf('DDP') >= 0 ? 1 : 0;
        q.oldenburg_z_in_government = parties.indexOf('Z') >= 0 ? 1 : 0;
        q.oldenburg_dvp_in_government = parties.indexOf('DVP') >= 0 ? 1 : 0;
        q.oldenburg_dnvp_in_government = parties.indexOf('DNVP') >= 0 ? 1 : 0;
        q.oldenburg_nsdap_in_government = parties.indexOf('NSDAP') >= 0 ? 1 : 0;

        q.oldenburg_leader_carl_rover_available = q.oldenburg_nsdap_in_government;
        q.oldenburg_leader_eugen_von_finckh_available = selected.technocratic ? 1 : 0;
        q.oldenburg_leader_friedrich_cassebohm_available = (q.oldenburg_dvp_in_government || q.oldenburg_dnvp_in_government) ? 1 : 0;
        q.oldenburg_leader_franz_driver_available = q.oldenburg_z_in_government;
        q.oldenburg_leader_theodor_tantzen_available = q.oldenburg_ddp_in_government;
        q.oldenburg_leader_paul_hug_available = q.oldenburg_spd_in_government;

        if (q.oldenburg_nsdap_in_government) {
            q.oldenburg_leader = 'Carl Röver';
        } else if (selected.technocratic) {
            q.oldenburg_leader = 'Eugen von Finckh';
        } else if (q.oldenburg_dvp_in_government || q.oldenburg_dnvp_in_government) {
            q.oldenburg_leader = 'Friedrich Cassebohm';
        } else if (q.oldenburg_z_in_government) {
            q.oldenburg_leader = 'Franz Driver';
        } else if (q.oldenburg_ddp_in_government) {
            q.oldenburg_leader = 'Theodor Tantzen';
        } else if (q.oldenburg_spd_in_government) {
            q.oldenburg_leader = 'Paul Hug';
        } else if (selected.technocratic) {
            q.oldenburg_leader = 'Eugen von Finckh';
        }
    };
    window.calculateOldenburgLandtagResults(Q);

window.calculatePrussianLandtagResults = function(qualities) {
        var q = qualities || Q;
        var prussianParties = q.parties || ['spd', 'kpd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'other'];
        var prussianSeatCount = q.prussia_landtag_seat_count || 450;
        q.prussia_landtag_seat_count = prussianSeatCount;
        var prussianWeights = {z: 1.26, dnvp: 1.17, kpd: 1.03, spd: 0.95, ddp: 0.91, nsdap: 0.87, dvp: 1.00, bvp: 1.00, wp: 1.00, other: 1.00};
        // TODO(prussia-election): add specific Prussian BVP/WP/Other weights if/when state weights are defined.
        q.prussia_party_weights = prussianWeights;
        var weightedVotes = {};
        var weightedTotal = 0;
        for (var prussianParty of prussianParties) {
            var federalVoteShare = Number(q[prussianParty + '_votes_raw']);
            if (isNaN(federalVoteShare)) {
                federalVoteShare = 100*(Number(q[prussianParty + '_normalized']) || 0);
            }
            if (isNaN(federalVoteShare) || federalVoteShare < 0) {
                federalVoteShare = 0;
            }
            var partyWeight = prussianWeights[prussianParty];
            if (partyWeight === undefined) {
                partyWeight = 1.00;
            }
            weightedVotes[prussianParty] = federalVoteShare*partyWeight;
            weightedTotal += weightedVotes[prussianParty];
        }
        var prussianVoteShares = {};
        for (var prussianShareParty of prussianParties) {
            var prussianRawShare = weightedTotal > 0 ? 100*weightedVotes[prussianShareParty]/weightedTotal : 0;
            q['prussia_' + prussianShareParty + '_votes_raw'] = prussianRawShare;
            q['prussia_' + prussianShareParty + '_votes'] = Math.round(prussianRawShare*10)/10;
            q['prussia_' + prussianShareParty + '_votes_disp'] = q['prussia_' + prussianShareParty + '_votes'].toFixed(1);
            q['prussia_' + prussianShareParty + '_votes_display'] = q['prussia_' + prussianShareParty + '_votes_disp'];
            q['prussia_' + prussianShareParty + '_result_votes'] = q['prussia_' + prussianShareParty + '_votes'];
            prussianVoteShares[prussianShareParty] = q['prussia_' + prussianShareParty + '_votes'];
        }
        var prussianBannedParties = {};
        for (var prussianBannedParty of prussianParties) {
            prussianBannedParties[prussianBannedParty] = q[prussianBannedParty + '_banned'];
        }
        var prussianSeats = window.allocateDhondtSeats(prussianVoteShares, prussianSeatCount, q.prussia_electoral_threshold || q.electoral_threshold || 0, {parties: prussianParties, banned: prussianBannedParties});
        q.prussia_landtag_total_seats = 0;
        for (var prussianSeatParty of prussianParties) {
            q['prussia_' + prussianSeatParty + '_r'] = prussianSeats[prussianSeatParty] || 0;
            q['prussia_' + prussianSeatParty + '_seats'] = q['prussia_' + prussianSeatParty + '_r'];
            q['prussia_' + prussianSeatParty + '_seat_share_disp'] = (Math.round((100*q['prussia_' + prussianSeatParty + '_r']/prussianSeatCount)*10)/10).toFixed(1);
            q.prussia_landtag_total_seats += q['prussia_' + prussianSeatParty + '_r'];
        }
        q.prussia_landtag_seat_allocation_valid = q.prussia_landtag_total_seats == prussianSeatCount ? 1 : 0;
        if (typeof window.updatePrussianCoalitionOptions === 'function') {
            window.updatePrussianCoalitionOptions(q);
        }
    };
    window.updatePrussianCoalitionOptions = function(qualities) {
        var q = qualities || Q;
        var threshold = Math.floor((q.prussia_landtag_seat_count || 450)/2) + 1;
        if (q.prussia_government == undefined || q.prussia_government == "SPD") {
            q.prussia_government = 1;
        }
        q.prussian_government = q.prussia_government;
        var options = [
            {id: 1, key: 'weimar', name: 'Weimar Coalition', parties: 'SPD + Z + DDP', seats: (Number(q.prussia_spd_r) || 0) + (Number(q.prussia_z_r) || 0) + (Number(q.prussia_ddp_r) || 0)},
            {id: 2, key: 'groko', name: 'GroKo', parties: 'SPD + Z + DDP + DVP', seats: (Number(q.prussia_spd_r) || 0) + (Number(q.prussia_z_r) || 0) + (Number(q.prussia_ddp_r) || 0) + (Number(q.prussia_dvp_r) || 0)},
            {id: 3, key: 'bourgeois', name: 'Bourgeois Coalition', parties: 'DVP + DNVP + DDP + Z', seats: (Number(q.prussia_dvp_r) || 0) + (Number(q.prussia_dnvp_r) || 0) + (Number(q.prussia_ddp_r) || 0) + (Number(q.prussia_z_r) || 0)},
            {id: 4, key: 'far_right', name: 'Far-Right Coalition', parties: 'NSDAP + DVP + DNVP + Z', seats: (Number(q.prussia_nsdap_r) || 0) + (Number(q.prussia_dvp_r) || 0) + (Number(q.prussia_dnvp_r) || 0) + (Number(q.prussia_z_r) || 0)}
        ];
        q.prussia_majority_threshold = threshold;
        for (var optionIndex = 0; optionIndex < options.length; optionIndex++) {
            var option = options[optionIndex];
            var prefix = 'prussia_' + option.key + '_coalition';
            var hasMajority = option.seats >= threshold;
            var isIncumbent = Number(q.prussia_government) === option.id;
            q[prefix + '_name'] = option.name;
            q[prefix + '_parties'] = option.parties;
            q[prefix + '_seats'] = option.seats;
            q[prefix + '_majority'] = hasMajority ? 1 : 0;
            q[prefix + '_status'] = hasMajority ? 'Majority' : 'Minority';
            q[prefix + '_selectable'] = hasMajority || isIncumbent ? 1 : 0;
        }
        var selected = options[(Number(q.prussia_government) || 1) - 1] || options[0];
        q.prussia_current_government_name = selected.name;
        q.prussia_current_government_parties = selected.parties;
        q.prussia_current_government_seats = selected.seats;
        q.prussia_majority_cabinet = selected.seats >= threshold ? 1 : 0;
        q.prussia_current_government_status = q.prussia_majority_cabinet ? 'Majority' : 'Minority';
        q.spd_prussia = Number(q.prussia_government) === 1 || Number(q.prussia_government) === 2 ? 1 : 0;
    };
    window.calculatePrussianLandtagResults(Q);
}


// Clamp DDP faction values between 0 and 100.
for (var faction of Q.ddp_factions || Q.factions) {
    if (Q[faction] === undefined || isNaN(Q[faction])) {
        Q[faction] = 0;
    }
    Q[faction] = Math.round(Q[faction]);
    if (Q[faction] < 0) {
        Q[faction] = 0;
    } else if (Q[faction] > 100) {
        Q[faction] = 100;
    }
}

// Keep deprecated SPD faction compatibility values sane while old scripts still mutate them.
if (Q.deprecated_spd_faction_vars) {
    for (var spdFactionVar of Q.deprecated_spd_faction_vars) {
        if (Q[spdFactionVar] === undefined || isNaN(Q[spdFactionVar])) {
            Q[spdFactionVar] = 0;
        }
    }
}

// TODO(DDP factions): Migrate remaining effects that read or write global dissent to DDP faction variables.
// Until then, derive overall dissent from the live deprecated SPD faction values so vote/support
// effects that scale by (1-dissent) continue to reflect internal-party unrest.
var deprecatedSpdFactions = ['left', 'center', 'labor', 'reformist', 'neorevisionist'];
var totalSpdStrength = 0;
var totalSpdDissent = 0;

for (var deprecatedSpdFaction of deprecatedSpdFactions) {
    var spdStrengthVar = deprecatedSpdFaction + '_strength';
    var spdDissentVar = deprecatedSpdFaction + '_dissent';

    if (Q[spdStrengthVar] === undefined || isNaN(Q[spdStrengthVar]) || Q[spdStrengthVar] < 0) {
        Q[spdStrengthVar] = 0;
    }
    if (Q[spdDissentVar] === undefined || isNaN(Q[spdDissentVar])) {
        Q[spdDissentVar] = 0;
    }

    Q[spdDissentVar] = Math.round(Q[spdDissentVar]);
    if (Q[spdDissentVar] < 0) {
        Q[spdDissentVar] = 0;
    } else if (Q[spdDissentVar] >= 100) {
        Q[spdDissentVar] = 99;
    }

    totalSpdStrength += Q[spdStrengthVar];
}

if (totalSpdStrength > 0) {
    for (var normalizedSpdFaction of deprecatedSpdFactions) {
        var normalizedSpdStrengthVar = normalizedSpdFaction + '_strength';
        var normalizedSpdDissentVar = normalizedSpdFaction + '_dissent';
        Q[normalizedSpdStrengthVar] = 100*Q[normalizedSpdStrengthVar]/totalSpdStrength;
        totalSpdDissent += Q[normalizedSpdStrengthVar]*Q[normalizedSpdDissentVar];
    }
    Q.dissent = 0.01*totalSpdDissent/100;
}

if (Q.unemployed <= 1) {
    Q.unemployed = 1;
}

Q.dissent_percent = Q.dissent*100;
console.log('new dissent: ' + Q.dissent);

if (Q.dissent < 0) {
    Q.dissent = 0;
} else if (Q.dissent > 0.95) {
    Q.dissent = 0.95;
}
Q.dissent_percent = Q.dissent*100;

// 1. update dates
if (Q.month_actions >= 1) {
    Q.time += 1;
    Q.month_actions = 0;
    Q.month += 1;
    if (Q.month >= 13) {
        Q.month = 1;
        Q.year += 1;
        if (Q.historical_mode) {
            Q.resources += 2;
        }
    }
    // decrement timers
    for (timer of Q.timers) {
        if (Q[timer+'_timer'] && Q[timer+'_timer'] > 0) {
            Q[timer+'_timer'] -= 1;
        }
    }
    // append to historical party support records
    var party_support_results = {'date': new Date(Q.year, Q.month - 1)};
    for (var party of Q.parties) {
        party_support_results[party] = Q[party + '_normalized']*100;
    }
    Q.party_support_records.push(party_support_results);
    Q.economic_records.push({'date': new Date(Q.year, Q.month - 1),
                             'inflation': Q.inflation,
                             'unemployment': Q.unemployed,
                             'elite_support': Q.elite_support});
    if (!Q.political_records) {
        Q.political_records = [];
    }
    Q.political_records.push({'date': new Date(Q.year, Q.month - 1),
                              'federalism': Q.federalism});
    // change economic stats...
    // we're basically implicity drawing a Philips curve
    // budget deficits lead to some inflation
    if (Q.budget <= 0 && Q.budget > -2 && Q.inflation < 2.5) {
        Q.inflation += 0.1;
    }
    if (Q.budget <= -2 && Q.budget > -5 && Q.inflation < 5) {
        Q.inflation += 0.2;
        if (Q.unemployed >= 12) {
            Q.inflation -= 0.1;
        }
    }
    if (Q.budget <= -5 && Q.inflation < 10) {
        Q.inflation += 0.3;
        if (Q.unemployed >= 15) {
            Q.inflation -= 0.1;
        }
    }
    // deflation is bad
    if (Q.inflation < -0.5 && Q.inflation > -5 && Q.unemployed < 15) {
        Q.unemployed += 0.2;
    }
    if (Q.inflation <= -5 && Q.unemployed < 20) {
        Q.unemployed += 0.3;
    }
    // economic growth
    if (Q.economic_growth < -0.5 && Q.unemployed <= 18) {
        Q.unemployed += 0.1;
    }
    if (Q.economic_growth < -5 && Q.unemployed <= 28) {
        Q.unemployed += 0.1;
    }
    if (Q.economic_growth >= 2 && Q.unemployed >= 17) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 4 && Q.unemployed >= 12) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 6 && Q.unemployed >= 7) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 8 && Q.unemployed >= 3) {
        Q.unemployed -= 0.1;
    }
    if (Q.economic_growth >= 4 && Q.inflation >= 7.5) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= -2.5 && Q.inflation <= -5) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= 7) {
        Q.economic_growth -= 0.1;
    }
    if (Q.economic_growth >= 10) {
        Q.economic_growth -= 0.2;
    }
    if (Q.economic_growth >= 12) {
        Q.economic_growth -= 0.3;
    }

    //////////////////////////////// Education & Science support/economic changes
    if (Q.major_curriculum && Q.major_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.5;
        }
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.3;
        }
    }
    // science bonus to economic growth
    // education bonus
    Q.science_bonus = 0;
    if (Q.education_science) {
        Q.science_bonus += Q.education_science;
    }
    if (Q.science) {
        if (Q.science >= 1) {
            Q.science_bonus += 1;
        } else if (Q.science >= 3) {
            Q.science_bonus += 2;
        } else if (Q.science >= 5) {
            Q.science_bonus += 3;
        }
    }
    if (Q.applied_research && Q.applied_research >= 1) {
        Q.science_bonus += 0.5*Q.applied_research;
    }
    // cap the science bonus at 6
    if (Q.science_bonus > 6) {
        Q.science_bonus = 6;
    }
    console.log(Q.science_bonus);
    // this is kinda messy but basically more science -> higher levels of baseline growth
    if (Q.science_bonus >= 1) {
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus + 3) {
            Q.economic_growth += 0.1;
        }
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus) {
            Q.economic_growth += 0.1;
        }
        if (Q.economic_growth < Q.science_bonus - 3) {
            Q.economic_growth += 0.1;
        }
    }
    // accumulated economic growth/decline
    // Maybe there should be differences for positive/negative growth?
    if (Q.economic_growth < 0) {
        if (Q.economic_expansion > 0) {
            Q.economic_expansion = 0;
        } else {
            Q.economic_expansion += Q.economic_growth;
        }
    }
    if (Q.economic_growth > 0 && Q.reparations <= -2 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth;
    } else if (Q.economic_growth > 0 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth/2;
    }
    /////////////////////////////// update opinions based on economy
    if (Q.unemployed > 15 && Q.pro_republic > 40) {
        Q.pro_republic -= 1;
    }
    if (Q.unemployed > 30 && Q.pro_republic > 20) {
        Q.pro_republic -= 1;
    }
    if (Q.inflation >= 8 && Q.pro_republic > 40) {
        Q.pro_republic -= 1;
    }

    ///////////////////////////// change elite/business confidence based on economic and political fundamentals
    Q.elite_support_pressure = 0;
    if (Q.upper_tax_rates > 0) {
        Q.elite_support_pressure -= Q.upper_tax_rates*0.2;
    }
    if (Q.tariffs >= 3) {
        Q.elite_support_pressure -= 0.2;
    }
    if (Q.budget <= -2) {
        Q.elite_support_pressure -= 0.2;
    }
    if (Q.budget <= -5) {
        Q.elite_support_pressure -= 0.3;
    }
    if (Q.inflation >= 8) {
        Q.elite_support_pressure -= 0.3;
    }
    if (Q.economic_growth >= 4) {
        Q.elite_support_pressure += 0.2;
    }
    if (Q.economic_growth < -2.5) {
        Q.elite_support_pressure -= 0.2;
    }
    if (Q.pro_republic >= 60) {
        Q.elite_support_pressure += 0.1;
    }
    if (Q.pro_republic < 40) {
        Q.elite_support_pressure -= 0.1;
    }
    Q.elite_support += Q.elite_support_pressure;
    Q.elite_support = Math.max(0, Math.min(100, Q.elite_support));

    ///////////////////////////// future culture-to-vote-share drift helpers
    // Future monthly culture drift should use cultureDriftStrength() to convert a
    // 0-100 culture variable into a -1..1 strength where 50 is neutral.
    // Then compute a tiny positive transfer amount and pass it to
    // moveTinySupportWithinVoterGroup() for each voter group. Do not call these
    // helpers until a later balance pass defines specific republicanism,
    // pacifism, feminism, nationalism, or secularism effects.
    var cultureDriftStrength = function(cultureVariable) {
        var cultureValue = typeof cultureVariable === 'number' ? cultureVariable : Q[cultureVariable];
        if (typeof cultureValue !== 'number' || isNaN(cultureValue)) {
            return 0;
        }
        cultureValue = Math.max(0, Math.min(100, cultureValue));
        return (cultureValue - 50)/50;
    };

    var moveTinySupportWithinVoterGroup = function(voterClass, sourceParties, targetParties, requestedTransfer) {
        if (typeof requestedTransfer !== 'number' || isNaN(requestedTransfer) || requestedTransfer <= 0) {
            return 0;
        }
        if (typeof sourceParties === 'string') {
            sourceParties = [sourceParties];
        }
        if (typeof targetParties === 'string') {
            targetParties = [targetParties];
        }
        if (!sourceParties || !targetParties || targetParties.length <= 0) {
            return 0;
        }

        var eligibleSources = [];
        var totalSourceSupport = 0;
        for (var sourceParty of sourceParties) {
            var sourceVariable = voterClass + '_' + sourceParty;
            if (typeof Q[sourceVariable] === 'number' && Q[sourceVariable] > 0) {
                eligibleSources.push({variable: sourceVariable, support: Q[sourceVariable]});
                totalSourceSupport += Q[sourceVariable];
            }
        }
        if (totalSourceSupport <= 0) {
            return 0;
        }

        var eligibleTargets = [];
        for (var targetParty of targetParties) {
            var targetVariable = voterClass + '_' + targetParty;
            if (typeof Q[targetVariable] === 'number') {
                eligibleTargets.push(targetVariable);
            }
        }
        if (eligibleTargets.length <= 0) {
            return 0;
        }

        // Cap the transfer at available source support so no party can go negative.
        // Because every subtracted point is re-added to eligible targets, the voter
        // group's total support is preserved apart from normal floating-point noise.
        var transfer = Math.min(requestedTransfer, totalSourceSupport);
        var movedSupport = 0;
        for (var eligibleSource of eligibleSources) {
            var sourceTransfer = transfer*(eligibleSource.support/totalSourceSupport);
            sourceTransfer = Math.min(Q[eligibleSource.variable], sourceTransfer);
            Q[eligibleSource.variable] -= sourceTransfer;
            movedSupport += sourceTransfer;
        }

        var supportPerTarget = movedSupport/eligibleTargets.length;
        for (var eligibleTarget of eligibleTargets) {
            Q[eligibleTarget] += supportPerTarget;
        }
        return movedSupport;
    };

    ///////////////////////////// change party support based on pro_republic
    // if pro_republic is less than the support of the Weimar coalition, reduce SPD support...
    if (Q.pro_republic < (Q.spd_votes + Q.ddp_votes + Q.z_votes)) {
        if (Q.new_middle_spd > 0) {
            Q.new_middle_spd -= 5/12;
            Q.new_middle_nsdap += 3/12;
        }
        if (Q.old_middle_spd > 0) {
            Q.old_middle_spd -= 5/12;
            Q.old_middle_nsdap += 3/12;
        }
        if (Q.rural_spd > 0) {
            Q.rural_spd -= 5/12;
            Q.rural_nsdap += 3/12;
        }
        if (Q.workers_spd_normalized > 30) {
            Q.workers_spd -= 4/12;
        }
        if (Q.catholics_spd > 0) {
            Q.catholics_spd -= 4/12;
        }
        if (Q.unemployed_spd_normalized > 10) {
            Q.unemployed_spd -= 4/12;
        }
        if (Q.new_middle_ddp > 0) {
            Q.new_middle_ddp -= 4/12;
            Q.new_middle_nsdap += 3/12;
        }
        if (Q.old_middle_ddp > 0) {
            Q.old_middle_ddp -= 5/12;
            Q.old_middle_nsdap += 4/12;
        }
        if (Q.rural_ddp > 0) {
            Q.rural_ddp -= 5/12;
            Q.rural_nsdap += 4/12;
        }
    }

    ////////////////////////// annual support changes
    if (Q.year == 1929) {
        Q.unemployed += 3/12;
        Q.inflation -= 1/12;
        // increase NSDAP vote share
        Q.new_middle_nsdap += 10/12;
        Q.old_middle_nsdap += 10/12;
        Q.new_middle_ddp -= 5/12;
        Q.new_middle_dvp -= 5/12;
        Q.workers_kpd += 5/12;
        Q.sa_strength += 50/12;
        Q.sh_strength += 100/12;
        Q.rural_dnvp -= 15/12;
        Q.rural_nsdap += 10/12;
        Q.unemployed_nsdap += 18/12;
    } else if (Q.year == 1930) {
        Q.rural_nsdap += 10/12;
        Q.rural_dnvp -= 15/12;
        Q.new_middle_dvp -= 5/12;
        Q.old_middle_dvp -= 6/12;
        Q.new_middle_ddp -= 5/12;
        Q.old_middle_ddp -= 6/12;
        Q.new_middle_nsdap += 10/12;
        Q.old_middle_nsdap += 10/12;
        Q.new_middle_other += 4/12;
        Q.old_middle_other += 4/12;
        Q.unemployed_nsdap += 8/12;
        Q.rural_other += 5/12;

        Q.workers_z += 1/12;
        Q.old_middle_z += 2/12;
        Q.new_middle_z += 2/12;
        if (!Q.works_program) {
            Q.rural_nsdap += 3/12;
            Q.old_middle_nsdap += 5/12;
            Q.workers_nsdap += 2/12;
            Q.workers_other += 5/12;
            Q.workers_kpd += 2/12;
        }
        Q.sa_strength += 100/12;
        Q.sh_strength += 100/12;
    } else if (Q.year == 1931) {
        Q.catholics_z += 2/12;
        Q.rural_dvp -= 8/12;
        Q.old_middle_dvp -= 8/12;
        Q.new_middle_dvp -= 8/12;
        Q.old_middle_ddp -= 8/12;
        Q.new_middle_ddp -= 8/12;
        Q.sa_strength += 50/12;
        Q.sh_strength += 50/12;
        Q.sa_militancy += 0.1/12;
        Q.old_middle_nsdap += 10/12;
        Q.rural_other -= 5/12;
        Q.rural_nsdap += 9/12;
        // TODO: economic policies should reduce NSDAP rurals
        if (!Q.works_program) {
            Q.old_middle_dvp -= 6/12;
            Q.new_middle_dvp -= 6/12;
            Q.rural_dvp -= 6/12;
            Q.workers -= 4/12;
            Q.unemployed_nsdap += 7/12;
            Q.unemployed_kpd += 2/12;
            Q.rural_other -= 12/12;
            Q.rural_nsdap += 12/12;
            Q.new_middle_nsdap += 12/12;
            Q.old_middle_nsdap += 12/12;
            Q.workers_nsdap += 2/12;
            Q.workers_kpd += 4/12;
            Q.sa_strength += 100/12;
            Q.sh_strength += 50/12;
        } else if (Q.unemployed > 15) {
            Q.old_middle_dvp -= 4/12;
            Q.new_middle_dvp -= 4/12;
            Q.rural_dvp -= 4/12;
            Q.unemployed_nsdap += 4/12;
            Q.old_middle_nsdap += 4/12;
            Q.new_middle_nsdap += 4/12;
            Q.rural_nsdap += 4/12;
        }
    } else if (Q.year == 1932) {
        Q.old_middle_other -= 7/12;
        Q.rural_other -= 7/12;
        Q.old_middle_nsdap += 7/12;
        Q.rural_nsdap += 7/12;
        Q.unemployed_nsdap += 4/12;
        if (!Q.works_program) {
            Q.unemployed += 5/12;
            Q.inflation -= 2/12;
            Q.catholics_z += 2/12;
            Q.workers -= 4/12;
            Q.rural_dnvp -= 4/12;
            Q.rural_nsdap += 8/12;
            Q.new_middle_nsdap += 10/12;
            Q.old_middle_nsdap += 10/12;
            Q.unemployed_nsdap += 8/12;
            Q.unemployed_kpd += 2/12;
            Q.workers_nsdap += 3/12;
            Q.workers_kpd += 3/12;
            Q.sa_strength += 200/12;
            Q.new_middle_dnvp += 4/12;
            Q.new_middle_dnvp += 4/12;
            Q.new_middle_dvp -= 4/12;
            Q.old_middle_dvp -= 4/12;
            Q.rural_dvp -= 4/12;
        } else if (Q.unemployed > 25) {
            Q.rural_nsdap += 5/12;
            Q.unemployed_nsdap += 5/12;
            Q.old_middle_nsdap += 5/12;
            Q.new_middle_nsdap += 4/12;
            Q.sa_strength += 50/12;
        } else if (Q.unemployed > 20) {
            Q.rural_nsdap += 2/12;
            Q.unemployed_nsdap += 3/12;
            Q.old_middle_nsdap += 3/12;
            Q.new_middle_nsdap += 2/12;
        }
    } else if (Q.year >= 1933) {
        if (Q.return_to_normalcy) {
            // return to normalcy -> voters return to the base
            if (Q.new_middle_ddp_normalized < 40) {
                Q.new_middle_ddp += 6/12;
            }
            if (Q.new_middle_dvp_normalized < 25) {
                Q.new_middle_dvp += 3/12;
            }
            if (Q.old_middle_dvp_normalized < 40) {
                Q.old_middle_dvp += 6/12;
            }
            if (Q.rural_dnvp_normalized < 40) {
                Q.rural_dnvp += 6/12;
            }
            if (Q.catholics_z_normalized < 40) {
                Q.catholics_z += 6/12;
            }
        }
        if (Q.unemployed > 20) {
            Q.rural_nsdap += 2/12;
            Q.unemployed_nsdap += 2/12;
            Q.old_middle_nsdap += 2/12;
            Q.new_middle_nsdap += 2/12;
            if (Q.spd_in_government) {
                Q.workers_spd -= 4/12;
            }
        }
    }
    // prevent forever support if the economy is bad
    if (Q.year >= 1934 && (Q.inflation >= 8 || Q.unemployed >= 20) && Q.pro_republic <= 45 && Q.spd_in_government) {
        if (Q.workers_spd_normalized > 40) {
            Q.workers_spd -= 6/12;
        }
        if (Q.unemployed_spd_normalized > 20) {
            Q.unemployed_spd -= 6/12;
        }
        if (Q.new_middle_spd_normalized > 20) {
            Q.new_middle_spd -= 6/12;
        }
        if (Q.old_middle_spd_normalized > 20) {
            Q.old_middle_spd -= 6/12;
        }
        if (Q.rural_spd_normalized > 20) {
            Q.rural_spd -= 6/12;
        }
        if (Q.catholics_spd_normalized > 20) {
            Q.catholics_spd -= 6/12;
        }
    }
}
Q.has_event = 0;
// check if there are any cards in #event, and then go to main if not.
var scene = this.game.scenes['post_event.events_choice'];
var choices = this._compileChoices(scene);
if (choices && choices[0].title != "Continue...") {
    Q.has_event = 1;
} else {
    has_event = 0;
}
// pre-load all of the event images
if (this.ui && this.ui.show_portraits) {
    for (var choice of choices) {
        var cc = this.game.scenes[choice.id];
        if (cc.faceImage) {
            var im = new Image();
            im.url = cc.faceImage;
        }
    }
}

if (typeof window !== "undefined" && window.generateBar) {
}
!}
go-to: events_choice if has_event = 1; main if has_event = 0 and difficulty >= 0; main.main_easy if has_event = 0 and difficulty < 0

= [+ month : month +] [+ year +]

@events_choice

- #event

# This scene is solely for updating numbers after events, and routing to special events.
