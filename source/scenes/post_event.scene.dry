// Monthly culture vote drift.
// Tiny monthly pressure from republican legitimacy toward/away from constitutional parties.
var REPUBLICANISM_MONTHLY_DRIFT_RATE = 0.05;
var PACIFISM_MONTHLY_DRIFT_RATE = 0.025;
var NATIONALISM_MONTHLY_DRIFT_RATE = 0.025;
var FEMINISM_MONTHLY_DRIFT_RATE = 0.015;
var SECULARISM_MONTHLY_DRIFT_RATE = 0.000625;
function transferVoteSupport(className, sourceParties, targetParties, totalTransfer) {
    if (totalTransfer <= 0) {
        return;
    }
    var sourceTotal = 0;
    for (var sourceParty of sourceParties) {
        var sourceKey = className + '_' + sourceParty;
        if (Q[sourceKey] === undefined || isNaN(Q[sourceKey])) {
            Q[sourceKey] = 0;
        }
        if (Q[sourceKey] > 0) {
            sourceTotal += Q[sourceKey];
        }
    }
    if (sourceTotal <= 0) {
        return;
    }
    var actualTransfer = Math.min(totalTransfer, sourceTotal);
    for (var targetParty of targetParties) {
        var targetKey = className + '_' + targetParty;
        if (Q[targetKey] === undefined || isNaN(Q[targetKey])) {
            Q[targetKey] = 0;
        }
    }
    for (var drainParty of sourceParties) {
        var drainKey = className + '_' + drainParty;
        var drainAmount = actualTransfer*(Math.max(0, Q[drainKey])/sourceTotal);
        Q[drainKey] = Math.max(0, Q[drainKey] - drainAmount);
    }
    for (var gainParty of targetParties) {
        var gainKey = className + '_' + gainParty;
        Q[gainKey] += actualTransfer/targetParties.length;
    }
}
if (Q.month_actions >= 1) {
    var monthlyVoteDriftClasses = ['workers', 'unemployed', 'catholics', 'old_middle', 'new_middle', 'rural'];
    var republicanismDriftScale = (Q.pro_republic - 50)/50;
    var republicanismMonthlyDrift = Math.abs(republicanismDriftScale)*REPUBLICANISM_MONTHLY_DRIFT_RATE;
    var antiRepublicanParties = ['nsdap', 'dnvp', 'kpd'];
    // TODO: future DNVP/DVP leader ideology can alter which parties benefit.
    var republicanParties = ['ddp', 'spd', 'z', 'bvp', 'dvp'];
    if (republicanismMonthlyDrift > 0) {
        for (var republicanismClass of monthlyVoteDriftClasses) {
            if (Q.classes.indexOf(republicanismClass) >= 0) {
                if (republicanismDriftScale > 0) {
                    transferVoteSupport(republicanismClass, antiRepublicanParties, republicanParties, republicanismMonthlyDrift);
                } else {
                    transferVoteSupport(republicanismClass, republicanParties, antiRepublicanParties, republicanismMonthlyDrift);
                }
            }
        }
    }

    var pacifismDriftScale = (Q.pacifism - 50)/50;
    var pacifismMonthlyDrift = Math.abs(pacifismDriftScale)*PACIFISM_MONTHLY_DRIFT_RATE;
    var pacifistBeneficiaryParties = ['ddp', 'dvp'];
    var militaristBeneficiaryParties = ['nsdap', 'dnvp'];
    // TODO: future hard-right DVP or moderated DNVP should change pacifism drift.
    if (pacifismMonthlyDrift > 0) {
