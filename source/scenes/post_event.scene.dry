title: Post Event
new-page: true
on-arrival: {!
Q.last_advisor_action = 0;
Q.last_cabinet_action = 0;
// Save migration/defaults for parties added after older saves were created.
var canonicalParties = ['spd', 'kpd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'dnvp', 'nsdap', 'other'];
if (!Q.parties) {
    Q.parties = canonicalParties;
} else {
    for (var migrationParty of canonicalParties) {
        if (Q.parties.indexOf(migrationParty) < 0) {
            Q.parties.push(migrationParty);
        }
    }
}
if (Q.bvp_relation == undefined) {
    Q.bvp_relation = Q.z_relation == undefined ? 50 : Q.z_relation;
}
if (Q.wp_relation == undefined) {
    Q.wp_relation = 50;
}
if (Q.prussia_election_year == undefined) {
    Q.prussia_election_year = Q.next_election_year || 1928;
}
if (Q.prussia_election_month == undefined) {
    Q.prussia_election_month = Q.next_election_month || 5;
}
if (Q.prussia_government == undefined || Q.prussia_government == "SPD") {
    Q.prussia_government = Q.prussian_government == undefined || Q.prussian_government == "SPD" ? 1 : Q.prussian_government;
}
if (Q.prussian_government == undefined || Q.prussian_government == "SPD") {
    Q.prussian_government = Q.prussia_government;
}
if (Q.prussia_majority_cabinet == undefined) {
    Q.prussia_majority_cabinet = 1;
}
if (Q.prussia_leader == undefined || Q.prussia_leader == "Braun") {
    Q.prussia_leader = "Otto Braun";
}

if (Q.prussia_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.prussia_leverage = 0;
}
if (Q.prussia_landtag_seat_count == undefined) {
    Q.prussia_landtag_seat_count = 450;
}
if (Q.bavaria_election_year == undefined) {
    Q.bavaria_election_year = 1928;
}
if (Q.bavaria_election_month == undefined) {
    Q.bavaria_election_month = 4;
}
if (Q.bavaria_government == undefined) {
    Q.bavaria_government = 2;
}
if (Q.bavaria_majority_cabinet == undefined) {
    Q.bavaria_majority_cabinet = 1;
}
if (Q.bavaria_leader == undefined) {
    Q.bavaria_leader = "Heinrich Held";
}

if (Q.bavaria_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.bavaria_leverage = 0;
}
// Bavaria uses a fixed 128-seat Landtag; force the value so older saves or test states cannot carry a stale seat count.
Q.bavaria_landtag_seat_count = 128;
if (Q.bavaria_peasant_party_name == undefined) {
    Q.bavaria_peasant_party_name = "Bavarian Peasant Party";
}
if (Q.baden_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.baden_leverage = 0;
}
if (Q.baden_election_year == undefined) {
    Q.baden_election_year = 1925;
}
if (Q.baden_election_month == undefined) {
    Q.baden_election_month = 10;
}
if (Q.baden_snap_election_called == undefined) {
    Q.baden_snap_election_called = 0;
}
if (Q.bremen_election_year == undefined) {
    Q.bremen_election_year = 1927;
}
if (Q.bremen_election_month == undefined) {
    Q.bremen_election_month = 11;
}
if (Q.bremen_government == undefined) {
    Q.bremen_government = 5;
}
if (Q.bremen_majority_cabinet == undefined) {
    Q.bremen_majority_cabinet = 1;
}
if (Q.bremen_leader == undefined) {
    Q.bremen_leader = "Theodor Spitta";
}

if (Q.bremen_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.bremen_leverage = 0;
}
if (Q.bremen_snap_election_called == undefined) {
    Q.bremen_snap_election_called = 0;
}
// Bremen uses a fixed 120-seat Bürgerschaft/Landtag.
Q.bremen_landtag_seat_count = 120;
if (Q.bremen_hausbesitzer_party_name == undefined) {
    Q.bremen_hausbesitzer_party_name = "Hausbesitzer Party";
}
if (Q.hamburg_election_year == undefined) {
    Q.hamburg_election_year = 1927;
}
if (Q.hamburg_election_month == undefined) {
    Q.hamburg_election_month = 10;
}
if (Q.hamburg_government == undefined) {
    Q.hamburg_government = 3;
}
if (Q.hamburg_majority_cabinet == undefined) {
    Q.hamburg_majority_cabinet = 1;
}
if (Q.hamburg_leader == undefined) {
    Q.hamburg_leader = "Rudolf Ross";
}

if (Q.hamburg_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.hamburg_leverage = 0;
}
if (Q.hamburg_snap_election_called == undefined) {
    Q.hamburg_snap_election_called = 0;
}
// Hamburg uses a fixed 160-seat Bürgerschaft/Landtag.
Q.hamburg_landtag_seat_count = 160;

if (Q.thuringia_election_year == undefined) {
    Q.thuringia_election_year = 1927;
}
if (Q.thuringia_election_month == undefined) {
    Q.thuringia_election_month = 1;
}
if (Q.thuringia_snap_election_called == undefined) {
    Q.thuringia_snap_election_called = 0;
}
if (Q.thuringia_government == undefined) {
    Q.thuringia_government = 5;
}
if (Q.thuringia_majority_cabinet == undefined) {
    Q.thuringia_majority_cabinet = 1;
}
if (Q.thuringia_leader == undefined) {
    Q.thuringia_leader = "Arnold Paulssen";
}
if (Q.thuringia_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
    Q.thuringia_leverage = 0;
}
Q.thuringia_landtag_seat_count = 56;
if (Q.thuringia_landtag_total_seats == undefined) {
    Q.thuringia_landtag_total_seats = 56;
}
if (Q.thuringia_landtag_seat_allocation_valid == undefined) {
    Q.thuringia_landtag_seat_allocation_valid = 1;
}

if (Q.saxony_election_year == undefined) {
    Q.saxony_election_year = 1926;
}
if (Q.saxony_election_month == undefined) {
    Q.saxony_election_month = 10;
}
if (Q.saxony_snap_election_called == undefined) {
    Q.saxony_snap_election_called = 0;
}
if (Q.saxony_government == undefined) {
    Q.saxony_government = 0;
}
if (Q.saxony_majority_cabinet == undefined) {
    Q.saxony_majority_cabinet = 0;
}
if (Q.saxony_leader == undefined) {
    Q.saxony_leader = "";
}

if (Q.saxony_leverage == undefined) {
    // Represents the DDP's ability to influence or block policies within this Land government.
