            q['bavaria_' + bavarianShareParty + '_result_votes'] = q['bavaria_' + bavarianShareParty + '_votes'];
            bavarianVoteShares[bavarianShareParty] = q['bavaria_' + bavarianShareParty + '_votes'];
        }
        var bavarianBannedParties = {};
        for (var bavarianBannedParty of bavarianParties) {
