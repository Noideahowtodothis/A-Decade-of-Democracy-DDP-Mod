@leader_anton_erkelenz
title: Adopt: Anton Erkelenz
choose-if: ddp_congress_leader_anton_erkelenz_available = 1 and ddp_leader != 1
unavailable-subtitle: [+ ddp_congress_leader_anton_erkelenz_debug +]
on-arrival: {! globalThis.adoptDdpCongressPosition(Q, 'leader', 'anton_erkelenz'); !}
go-to: conclusion

