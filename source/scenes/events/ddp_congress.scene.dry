- @delegate_election: Continue to delegate election

@delegate_election
on-arrival: {! globalThis.prepareDdpCongress(Q); !}
on-display: {!
var ddpCongressDelegateChart = document.getElementById('ddp_congress_delegate_chart');
if (ddpCongressDelegateChart && typeof renderParliamentChart === 'function') {
    var data = [
        { id: 'ddp_left_progressive', legend: 'Left Progressive', name: 'Left Progressive', seats: Number(Q.ddp_left_progressive_delegate_share) || 0, color: '#E3000F' },
        { id: 'ddp_laborist', legend: 'Laborist', name: 'Laborist', seats: Number(Q.ddp_laborist_delegate_share) || 0, color: '#D5AC27' },
        { id: 'ddp_left_liberal', legend: 'Left Liberal', name: 'Left Liberal', seats: Number(Q.ddp_left_liberal_delegate_share) || 0, color: '#DCCA4A' },
        { id: 'ddp_left_bourgeois', legend: 'Left Bourgeois', name: 'Left Bourgeois', seats: Number(Q.ddp_left_bourgeois_delegate_share) || 0, color: '#3f7bc1' },
        { id: 'ddp_regionalist', legend: 'Regionalist', name: 'Regionalist', seats: Number(Q.ddp_regionalist_delegate_share) || 0, color: '#5E8C31' }
    ];
    renderParliamentChart("ddp_congress_delegate_chart", data);
}
!}

