title: DDP Party Congress
subtitle: Mechanical first version
new-page: true
tags: event
view-if: (year = 1925 and month = 12 and not ddp_congress_1925_12_done) or (year = 1927 and month = 4 and not ddp_congress_1927_04_done) or (year = 1929 and month = 10 and not ddp_congress_1929_10_done) or (year = 1931 and month = 3 and not ddp_congress_1931_03_done) or (year = 1933 and month = 8 and not ddp_congress_1933_08_done)
max-visits: 5
on-arrival: {!
Q.ddp_congress_active = true;
Q.ddp_congress_current_date = Q.year + '-' + (Q.month < 10 ? '0' + Q.month : '' + Q.month);
if (Q.year == 1925 && Q.month == 12) { Q.ddp_congress_1925_12_done = 1; }
if (Q.year == 1927 && Q.month == 4) { Q.ddp_congress_1927_04_done = 1; }
if (Q.year == 1929 && Q.month == 10) { Q.ddp_congress_1929_10_done = 1; }
if (Q.year == 1931 && Q.month == 3) { Q.ddp_congress_1931_03_done = 1; }
if (Q.year == 1933 && Q.month == 8) { Q.ddp_congress_1933_08_done = 1; }

if (typeof globalThis !== 'undefined') {
    globalThis.ddpCongressFactionLabels = {
        ddp_left_progressive: 'Left Progressive',
        ddp_laborist: 'Laborist',
        ddp_left_liberal: 'Left Liberal',
        ddp_left_bourgeois: 'Left Bourgeois',
        ddp_regionalist: 'Regionalist'
    };
    globalThis.ddpCongressIssues = {nationalism:{label:'Nationalism', variable:'ddp_nationalism_position', positions:[{code:'oppose_extreme_nationalism', value:1, label:'Oppose Extreme Nationalism', support:['ddp_left_progressive'], neutral:['ddp_left_liberal'], oppose:['ddp_laborist','ddp_left_bourgeois','ddp_regionalist']},{code:'liberal_civic_nationalism', value:2, label:'Support Liberal Civic Nationalism', support:['ddp_left_liberal'], neutral:['ddp_left_progressive','ddp_laborist','ddp_left_bourgeois'], oppose:['ddp_regionalist']},{code:'political_benefit_nationalism', value:3, label:'Use Nationalism for Political Benefit', support:['ddp_left_bourgeois','ddp_regionalist'], neutral:['ddp_laborist','ddp_left_liberal'], oppose:['ddp_left_progressive']},{code:'german_racial_nationalism', value:4, label:'Support German Racial Nationalism', support:['ddp_regionalist'], neutral:['ddp_left_bourgeois'], oppose:['ddp_left_progressive','ddp_laborist','ddp_left_liberal']}]},economic:{label:'Economics', variable:'ddp_economics_position', positions:[{code:'interventionist_economics', value:1, label:'Support Interventionist Economics', support:['ddp_left_progressive','ddp_laborist'], neutral:['ddp_left_liberal'], oppose:['ddp_left_bourgeois','ddp_regionalist']},{code:'social_liberal_economy', value:2, label:'Support a Social Liberal Economy', support:['ddp_left_progressive','ddp_laborist','ddp_left_liberal'], neutral:[], oppose:['ddp_left_bourgeois','ddp_regionalist']},{code:'liberal_economics', value:3, label:'Support Liberal Economics', support:['ddp_left_bourgeois','ddp_regionalist'], neutral:['ddp_left_liberal'], oppose:['ddp_left_progressive','ddp_laborist']},{code:'agrarian_interests', value:4, label:'Focus on Agrarian Interests', support:['ddp_regionalist'], neutral:[], oppose:['ddp_left_progressive','ddp_laborist','ddp_left_liberal','ddp_left_bourgeois']}]},republic:{label:'The Republic', variable:'ddp_republic_position', positions:[{code:'cornerstone_republic', value:1, label:'Make Ourselves the Cornerstone of the Republic', support:['ddp_left_liberal','ddp_left_progressive','ddp_laborist'], neutral:[], oppose:['ddp_left_bourgeois','ddp_regionalist']},{code:'quiet_republic', value:2, label:'Support the Republic Quietly', support:['ddp_left_bourgeois','ddp_regionalist'], neutral:[], oppose:['ddp_left_progressive','ddp_laborist','ddp_left_liberal']}]},federalism:{label:'Federalism', variable:'ddp_federalism_position', positions:[{code:'expand_federal_powers', value:1, label:'Expand Federal Powers', support:['ddp_regionalist'], neutral:['ddp_left_progressive','ddp_laborist','ddp_left_liberal','ddp_left_bourgeois'], oppose:[]},{code:'expand_central_power', value:2, label:'Expand Central Power', support:['ddp_left_progressive','ddp_laborist','ddp_left_liberal','ddp_left_bourgeois'], neutral:[], oppose:['ddp_regionalist']},{code:'unitary_state', value:3, label:'Support a Unitary State', support:['ddp_left_progressive'], neutral:['ddp_laborist','ddp_left_liberal','ddp_left_bourgeois'], oppose:['ddp_regionalist']}]},leader:{label:'Leader', variable:'ddp_leader', positions:[{code:'anton_erkelenz', value:1, label:'Anton Erkelenz', ideology:'left-social liberal', support:['ddp_left_progressive','ddp_laborist'], neutral:[], oppose:['ddp_left_liberal','ddp_left_bourgeois','ddp_regionalist']},{code:'theodor_heuss', value:2, label:'Theodor Heuss', ideology:'progressive republican liberal', support:['ddp_left_progressive','ddp_left_liberal'], neutral:['ddp_laborist'], oppose:['ddp_left_bourgeois','ddp_regionalist']},{code:'theodor_maier', value:3, label:'Theodor Maier', ideology:'left-liberal', support:['ddp_left_liberal','ddp_left_bourgeois'], neutral:[], oppose:['ddp_left_progressive','ddp_laborist','ddp_regionalist']},{code:'otto_fischbeck', value:4, label:'Otto Fischbeck', ideology:'federal/regional liberal', support:['ddp_regionalist'], neutral:['ddp_left_bourgeois'], oppose:['ddp_left_progressive','ddp_laborist','ddp_left_liberal']},{code:'erich_koch_weser', value:5, label:'Erich Koch-Weser', ideology:'bourgeois republican liberal', support:['ddp_left_bourgeois','ddp_left_liberal'], neutral:['ddp_left_progressive','ddp_laborist','ddp_regionalist'], oppose:[]},{code:'hermann_dietrich', value:6, label:'Hermann Dietrich', ideology:'agrarian-bourgeois liberal', support:['ddp_regionalist','ddp_left_bourgeois'], neutral:[], oppose:['ddp_left_progressive','ddp_laborist','ddp_left_liberal']}]}};
    globalThis.prepareDdpCongress = function(qualities) {
        var factions = ['ddp_left_progressive', 'ddp_laborist', 'ddp_left_liberal', 'ddp_left_bourgeois', 'ddp_regionalist'];
        var factionStrengthDefaults = {
            ddp_left_bourgeois: 35,
            ddp_left_liberal: 30,
            ddp_regionalist: 15,
            ddp_laborist: 10,
            ddp_left_progressive: 10
        };
        qualities.ddp_factions = factions;
        qualities.ddp_faction_strength_defaults = factionStrengthDefaults;
        if (!qualities.ddp_faction_dissent_variables) {
            qualities.ddp_faction_dissent_variables = [];
        }
        var strengthTotal = 0;
        for (var i = 0; i < factions.length; i++) {
            var faction = factions[i];
            if (qualities[faction] === undefined || qualities[faction] === null || isNaN(qualities[faction])) {
                qualities[faction] = factionStrengthDefaults[faction];
            }
            if (qualities[faction] < 0) {
                qualities[faction] = 0;
            }
            strengthTotal += qualities[faction];
            if (qualities[faction + '_dissent'] === undefined || isNaN(qualities[faction + '_dissent'])) {
                qualities[faction + '_dissent'] = 0;
            }
            qualities[faction + '_dissent'] = Math.max(0, Math.min(100, Math.round(qualities[faction + '_dissent'])));
            if (qualities.ddp_faction_dissent_variables.indexOf(faction + '_dissent') < 0) {
                qualities.ddp_faction_dissent_variables.push(faction + '_dissent');
            }
        }
        if (strengthTotal <= 0) {
            strengthTotal = 0;
            for (var defaultIndex = 0; defaultIndex < factions.length; defaultIndex++) {
                var defaultFaction = factions[defaultIndex];
                qualities[defaultFaction] = factionStrengthDefaults[defaultFaction];
                strengthTotal += qualities[defaultFaction];
            }
        }
        qualities.ddp_congress_total_strength = strengthTotal;
        qualities.ddp_congress_delegate_basis = 'Faction strength normalized to 100 delegates.';
        for (var j = 0; j < factions.length; j++) {
            var delegateFaction = factions[j];
            var delegateValue = strengthTotal > 0 ? 100*qualities[delegateFaction]/strengthTotal : 20;
            qualities[delegateFaction + '_delegates'] = delegateValue;
            qualities[delegateFaction + '_delegates_display'] = (Math.round(delegateValue*10)/10).toFixed(1);
        }
        // Preserve the fractional delegate weights above for existing congress mechanics, while
        // apportioning the displayed congress shares as whole delegates that always total 100.
        var apportionedDelegates = 0;
        var delegateRemainders = [];
        for (var d = 0; d < factions.length; d++) {
            var apportionedFaction = factions[d];
            var exactDelegateShare = qualities[apportionedFaction + '_delegates'];
            var wholeDelegateShare = Math.floor(exactDelegateShare);
            qualities[apportionedFaction + '_delegate_share'] = wholeDelegateShare;
            apportionedDelegates += wholeDelegateShare;
            delegateRemainders.push({faction: apportionedFaction, remainder: exactDelegateShare - wholeDelegateShare, order: d});
        }
        delegateRemainders.sort(function(a, b) {
            return b.remainder - a.remainder || a.order - b.order;
        });
        for (var r = 0; r < 100 - apportionedDelegates; r++) {
            qualities[delegateRemainders[r].faction + '_delegate_share'] += 1;
        }
        qualities.ddp_congress_delegate_share_total = 100;
        var issues = globalThis.ddpCongressIssues;
        for (var issueKey in issues) {
            var issue = issues[issueKey];
            qualities['ddp_congress_' + issueKey + '_selectable'] = 0;
            for (var p = 0; p < issue.positions.length; p++) {
                var position = issue.positions[p];
                var supportTotal = 0;
                var opposeTotal = 0;
                for (var s = 0; s < position.support.length; s++) {
                    supportTotal += qualities[position.support[s] + '_delegates'] || 0;
                }
                for (var o = 0; o < position.oppose.length; o++) {
                    opposeTotal += qualities[position.oppose[o] + '_delegates'] || 0;
                }
                var prefix = 'ddp_congress_' + issueKey + '_' + position.code;
                qualities[prefix + '_support'] = Math.round(supportTotal*10)/10;
                qualities[prefix + '_oppose'] = Math.round(opposeTotal*10)/10;
                qualities[prefix + '_support_display'] = qualities[prefix + '_support'].toFixed(1);
                qualities[prefix + '_oppose_display'] = qualities[prefix + '_oppose'].toFixed(1);
                qualities[prefix + '_available'] = supportTotal > opposeTotal ? 1 : 0;
                if (qualities[prefix + '_available'] && qualities[issue.variable] != position.value) {
                    qualities['ddp_congress_' + issueKey + '_selectable'] = 1;
                }
                qualities[prefix + '_debug'] = 'Support ' + qualities[prefix + '_support_display'] + ' vs oppose ' + qualities[prefix + '_oppose_display'] + '. ' + (supportTotal > opposeTotal ? 'Available.' : 'Blocked: supporting delegates must outnumber opposing delegates.');
            }
        }
    };
    globalThis.adoptDdpCongressPosition = function(qualities, issueKey, positionCode) {
        globalThis.prepareDdpCongress(qualities);
        var issue = globalThis.ddpCongressIssues[issueKey];
        if (!issue) { return; }
        var selected = null;
        for (var i = 0; i < issue.positions.length; i++) {
            if (issue.positions[i].code == positionCode) {
                selected = issue.positions[i];
            }
        }
        if (!selected) { return; }
        var prefix = 'ddp_congress_' + issueKey + '_' + selected.code;
        if (!qualities[prefix + '_available']) { return; }
        qualities[issue.variable] = selected.value;
        if (issueKey == 'leader') {
            qualities.ddp_ideology = selected.ideology;
        }
        // TODO(DDP congress): Add culture and election effects after the issue-voting layer is established.
        qualities.ddp_congress_last_adopted = selected.label;
        for (var s = 0; s < selected.support.length; s++) {
            var supportFaction = selected.support[s];
            qualities[supportFaction + '_dissent'] = Math.max(0, Math.min(100, (qualities[supportFaction + '_dissent'] || 0) - 2));
        }
        for (var o = 0; o < selected.oppose.length; o++) {
            var opposeFaction = selected.oppose[o];
            qualities[opposeFaction + '_dissent'] = Math.max(0, Math.min(100, (qualities[opposeFaction + '_dissent'] || 0) + 5));
        }
        globalThis.prepareDdpCongress(qualities);
    };
}
globalThis.prepareDdpCongress(Q);
!}

= DDP Party Congress

