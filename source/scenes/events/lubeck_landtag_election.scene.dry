title: Lübeck Bürgerschaft/Landtag Elections
new-page: true
tags: event
priority: -2
view-if: (year = lubeck_election_year and month >= lubeck_election_month) or (year > lubeck_election_year)
on-departure: lubeck_election_year = lubeck_election_year + 4 if lubeck_snap_election_called == 0; lubeck_election_year = year + 4 if lubeck_snap_election_called == 1; lubeck_election_month = month if lubeck_snap_election_called == 1; lubeck_snap_election_called = 0
set-jump: lubeck_landtag_results

= Lübeck Bürgerschaft/Landtag Elections, [+ month : month +] [+ year +]

Lübeck holds elections with **80** seats allocated by D’Hondt.

- @calculate_lubeck_landtag: Count the votes.

@calculate_lubeck_landtag
on-arrival: lubeck_government = 3 if lubeck_government == undefined; lubeck_leader = "Rudolf Keibel" if lubeck_leader == undefined; lubeck_majority_cabinet = 1 if lubeck_majority_cabinet == undefined
go-to: election_algorithm
set-jump: lubeck_landtag_results

@lubeck_landtag_results
on-arrival: {! var isSnap = Number(Q.lubeck_snap_election_called) === 1; Q.lubeck_next_election_year_preview = (isSnap ? (Number(Q.year) || 0) : (Number(Q.lubeck_election_year) || Number(Q.year) || 0)) + 4; Q.lubeck_next_election_month_preview = isSnap ? Q.month : Q.lubeck_election_month; if (typeof window !== 'undefined' && typeof window.calculateLubeckLandtagResults === 'function') { window.calculateLubeckLandtagResults(Q); } !}

