view-if: bavaria_bvp_peasant_dnvp_coalition_selectable = 1
on-arrival: {! Q.bavaria_government = 2; if (typeof window !== 'undefined' && typeof window.updateBavarianCoalitionOptions === 'function') { window.updateBavarianCoalitionOptions(Q); } !}
go-to: bavaria_leader_selection

@bavaria_select_bvp_dnvp
