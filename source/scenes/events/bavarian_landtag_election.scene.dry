go-to: bavaria_leader_selection

@new_bavarian_elections
title: Call new Bavarian Landtag elections.
on-arrival: bavaria_election_year = year; bavaria_election_month = month
go-to: calculate_bavarian_landtag

@bavaria_leader_selection

= Choose the Bavarian leader

Selected coalition: **[+ bavaria_current_government_name +]** ([+ bavaria_current_government_parties +]).

Coalition seats: **[+ bavaria_current_government_seats +] / 128**. Status: **[+ bavaria_current_government_status +]**.

- @bavaria_leader_vogel
- @bavaria_leader_held

@bavaria_leader_vogel
title: Kurt Vogel
subtitle: Available because the SPD is in the Bavarian cabinet.
view-if: bavaria_government = 1
on-arrival: bavaria_leader = "Kurt Vogel"
go-to: bavarian_government_confirmed

@bavaria_leader_held
title: Heinrich Held
subtitle: Available because BVP/Z is in the Bavarian cabinet.
view-if: bavaria_government = 2 or bavaria_government = 3 or bavaria_government = 4
on-arrival: bavaria_leader = "Heinrich Held"
go-to: bavarian_government_confirmed

@bavarian_government_confirmed
on-arrival: {!
var totalSeats = Number(Q.bavaria_landtag_total_seats) || 128;
var ddpSeats = Number(Q.bavaria_ddp_r) || 0;
var ddpShare = totalSeats > 0 ? (ddpSeats / totalSeats) * 100 : 0;
var base = 0;
if (ddpShare >= 30) { base = 5; }
else if (ddpShare >= 20) { base = 4; }
else if (ddpShare >= 15) { base = 3; }
else if (ddpShare >= 10) { base = 2; }
else if (ddpShare >= 5) { base = 1; }

var coalitionParties = [];
var coalitionSeats = Number(Q.bavaria_current_government_seats) || 0;
var gov = Number(Q.bavaria_government) || 1;
if (gov === 1) { coalitionParties = ['ddp', 'peasant', 'spd']; }
else if (gov === 2) { coalitionParties = ['bvp_z', 'peasant', 'dnvp']; }
else if (gov === 3) { coalitionParties = ['bvp_z', 'dnvp']; }
else if (gov === 4) { coalitionParties = ['bvp_z', 'ddp', 'peasant']; }

var majorityThreshold = Math.floor(totalSeats / 2) + 1;
var pivotal = (coalitionSeats >= majorityThreshold && (coalitionSeats - ddpSeats) < majorityThreshold) ? 2 : 0;

var ddpInCoalition = coalitionParties.indexOf('ddp') !== -1;
var dominant = 0;
if (ddpInCoalition) {
  dominant = 1;
  for (var i = 0; i < coalitionParties.length; i += 1) {
    var party = coalitionParties[i];
    if (party === 'ddp') { continue; }
    var partySeats = Number(Q['bavaria_' + party + '_r']) || 0;
    if (partySeats >= ddpSeats) { dominant = 0; break; }
  }
}

var hostilePenalty = 0;
if (coalitionParties.indexOf('dnvp') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('nsdap') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('kpd') !== -1) { hostilePenalty += 1; }

var ddpLeaderPenalty = 0; // No selectable Bavarian DDP leader.

var leverage = ddpInCoalition ? base + pivotal + dominant - hostilePenalty - ddpLeaderPenalty : 0;
if (leverage < 0) { leverage = 0; }
if (leverage > 8) { leverage = 8; }
Q.bavaria_leverage = leverage;
!}

