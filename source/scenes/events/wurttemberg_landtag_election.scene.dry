@wurttemberg_government_confirmed
on-arrival: {!
var totalSeats = Number(Q.wurttemberg_landtag_total_seats) || 80;
var ddpSeats = Number(Q.wurttemberg_ddp_r) || 0;
var ddpShare = totalSeats > 0 ? (ddpSeats / totalSeats) * 100 : 0;
var base = 0;
if (ddpShare >= 30) { base = 5; }
else if (ddpShare >= 20) { base = 4; }
else if (ddpShare >= 15) { base = 3; }
else if (ddpShare >= 10) { base = 2; }
else if (ddpShare >= 5) { base = 1; }

var coalitionParties = [];
var coalitionSeats = Number(Q.wurttemberg_current_government_seats) || 0;
var gov = Number(Q.wurttemberg_government) || 1;
if (gov === 1) { coalitionParties = ['spd', 'ddp']; }
else if (gov === 2) { coalitionParties = ['spd', 'ddp', 'dvp']; }
else if (gov === 3) { coalitionParties = ['spd', 'ddp', 'z', 'dvp']; }
else if (gov === 4) { coalitionParties = ['ddp', 'z', 'dvp']; }
else if (gov === 5) { coalitionParties = ['ddp', 'z', 'dvp', 'wbwb']; }
else if (gov === 6) { coalitionParties = ['z', 'dvp', 'wbwb', 'dnvp']; }
else if (gov === 7) { coalitionParties = ['z', 'wbwb', 'dnvp']; }
else if (gov === 8) { coalitionParties = ['z', 'wbwb', 'dnvp', 'csvd']; }
else if (gov === 9) { coalitionParties = ['wbwb', 'dnvp', 'nsdap']; }

var majorityThreshold = Math.floor(totalSeats / 2) + 1;
var pivotal = (coalitionSeats >= majorityThreshold && (coalitionSeats - ddpSeats) < majorityThreshold) ? 2 : 0;

var ddpInCoalition = coalitionParties.indexOf('ddp') !== -1;
var dominant = 0;
if (ddpInCoalition) {
  dominant = 1;
  for (var i = 0; i < coalitionParties.length; i += 1) {
    var party = coalitionParties[i];
    if (party === 'ddp') { continue; }
    var partySeats = Number(Q['wurttemberg_' + party + '_r']) || 0;
    if (partySeats >= ddpSeats) { dominant = 0; break; }
  }
}

var hostilePenalty = 0;
if (coalitionParties.indexOf('dnvp') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('nsdap') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('kpd') !== -1) { hostilePenalty += 1; }

var ddpLeaderPenalty = 0;
if (["Reinhold Maier", "Johannes Hieber"].indexOf(Q.wurttemberg_leader) !== -1) { ddpLeaderPenalty = 1; }

var leverage = ddpInCoalition ? base + pivotal + dominant - hostilePenalty - ddpLeaderPenalty : 0;
if (leverage < 0) { leverage = 0; }
if (leverage > 8) { leverage = 8; }
Q.wurttemberg_leverage = leverage;
!}
title: Württemberg government formed

= Württemberg government formed
Coalition: **[+ wurttemberg_current_government_name +]**

Seats: **[+ wurttemberg_current_government_seats +] / 80**

Status: **[+ wurttemberg_current_government_status +]**

Leader: **[+ wurttemberg_leader +]**

Next Württemberg election: **[+ wurttemberg_next_election_month_preview : month +] [+ wurttemberg_next_election_year_preview +]**.

- @root: Continue.
