title: Württemberg Landtag Elections
new-page: true
tags: event
priority: 1
view-if: (year = wurttemberg_election_year and month >= wurttemberg_election_month) or (year > wurttemberg_election_year)
on-departure: wurttemberg_election_year = wurttemberg_election_year + 4 if wurttemberg_snap_election_called == 0; wurttemberg_election_year = year + 4 if wurttemberg_snap_election_called == 1; wurttemberg_election_month = month if wurttemberg_snap_election_called == 1; wurttemberg_snap_election_called = 0
set-jump: wurttemberg_landtag_results

= Württemberg Landtag Elections, [+ month : month +] [+ year +]

Württemberg holds Landtag elections with **80** seats allocated by D’Hondt.

- @calculate_wurttemberg_landtag: Count the votes.

@calculate_wurttemberg_landtag
on-arrival: wurttemberg_government = 4 if wurttemberg_government == undefined; wurttemberg_leader = "Eugen Bolz" if wurttemberg_leader == undefined; wurttemberg_majority_cabinet = 1 if wurttemberg_majority_cabinet == undefined
go-to: election_algorithm
set-jump: wurttemberg_landtag_results

@wurttemberg_landtag_results
on-arrival: {! Q.wurttemberg_next_election_year_preview = Number(Q.wurttemberg_election_year) || Number(Q.year) || 0; Q.wurttemberg_next_election_month_preview = Q.wurttemberg_election_month; if (typeof window !== 'undefined' && typeof window.calculateWurttembergLandtagResults === 'function') { window.calculateWurttembergLandtagResults(Q); } !}
on-display: {!
var wurttembergLandtagChart = document.getElementById('wurttemberg_landtag_chart');
if (wurttembergLandtagChart && typeof d3 !== 'undefined' && typeof d3.parliament === 'function') {
    wurttembergLandtagChart.innerHTML = '';
    var data = [
        { id: 'spd', legend: 'SPD', name: 'SPD', seats: Number(Q.wurttemberg_spd_r) || 0, color: '#E3000F' },
        { id: 'ddp', legend: Q.ddp_name || 'DDP', name: Q.ddp_name || 'DDP', seats: Number(Q.wurttemberg_ddp_r) || 0, color: '#DCCA4A' },
        { id: 'dvp', legend: 'DVP', name: 'DVP', seats: Number(Q.wurttemberg_dvp_r) || 0, color: '#D5AC27' },
        { id: 'z', legend: 'Z', name: 'Z', seats: Number(Q.wurttemberg_z_r) || 0, color: '#000000' },
        { id: 'kpd', legend: 'KPD', name: 'KPD', seats: Number(Q.wurttemberg_kpd_r) || 0, color: '#8B0000' },
        { id: 'dnvp', legend: 'DNVP', name: 'DNVP', seats: Number(Q.wurttemberg_dnvp_r) || 0, color: '#3f7bc1' },
        { id: 'csvd', legend: 'CSVD', name: 'CSVD', seats: Number(Q.wurttemberg_csvd_r) || 0, color: '#4F8F46' },
        { id: 'wbwb', legend: 'WBWB', name: 'WBWB', seats: Number(Q.wurttemberg_wbwb_r) || 0, color: '#5E8C31' },
        { id: 'nsdap', legend: 'NSDAP', name: 'NSDAP', seats: Number(Q.wurttemberg_nsdap_r) || 0, color: '#954B00' },
        { id: 'other', legend: 'Other', name: 'Other', seats: Number(Q.wurttemberg_other_r) || 0, color: '#a0a0a0' }
    ];
    var parliament = d3.parliament();
    parliament.width(320).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select(wurttembergLandtagChart).datum(data).call(parliament);
}
!}

= Württemberg Landtag election results

Next Württemberg election is due in **[+ wurttemberg_next_election_month_preview : month +] [+ wurttemberg_next_election_year_preview +]**.

Württemberg Landtag seats: **[+ wurttemberg_landtag_total_seats +] / 80**

Current Württemberg government: **[+ wurttemberg_current_government_name +]** ([+ wurttemberg_current_government_parties +]) led by **[+ wurttemberg_leader +]**.

Current government seats: **[+ wurttemberg_current_government_seats +] / 80**. Status: **[+ wurttemberg_current_government_status +]**. Majority cabinet: **[+ wurttemberg_majority_cabinet +]**.

Current government leverage: **[+ wurttemberg_leverage +]**.

