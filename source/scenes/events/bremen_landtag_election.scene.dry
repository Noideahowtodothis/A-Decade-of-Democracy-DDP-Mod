on-arrival: {! Q.bremen_government = 3; if (typeof window !== 'undefined' && typeof window.updateBremenCoalitionOptions === 'function') { window.updateBremenCoalitionOptions(Q); } !}
go-to: bremen_leader_selection

@bremen_select_spd_ddp_dvp
title: SPD-DDP-DVP
subtitle: SPD + DDP + DVP — [+ bremen_spd_ddp_dvp_coalition_seats +] / 120 — [+ bremen_spd_ddp_dvp_coalition_status +]
view-if: bremen_spd_ddp_dvp_coalition_selectable = 1
on-arrival: {! Q.bremen_government = 4; if (typeof window !== 'undefined' && typeof window.updateBremenCoalitionOptions === 'function') { window.updateBremenCoalitionOptions(Q); } !}
go-to: bremen_leader_selection

@bremen_select_dvp_dnvp_ddp_hausbesitzer
title: DVP-DNVP-DDP-Hausbesitzer
subtitle: DVP + DNVP + DDP + Hausbesitzer — [+ bremen_dvp_dnvp_ddp_hausbesitzer_coalition_seats +] / 120 — [+ bremen_dvp_dnvp_ddp_hausbesitzer_coalition_status +]
view-if: bremen_dvp_dnvp_ddp_hausbesitzer_coalition_selectable = 1
on-arrival: {! Q.bremen_government = 5; if (typeof window !== 'undefined' && typeof window.updateBremenCoalitionOptions === 'function') { window.updateBremenCoalitionOptions(Q); } !}
go-to: bremen_leader_selection

@new_bremen_elections
title: Call new Bremen Bürgerschaft elections.
