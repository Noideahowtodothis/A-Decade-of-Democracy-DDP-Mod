go-to: calculate_bremen_landtag

@bremen_leader_selection

= Choose the Bremen leader

Selected coalition: **[+ bremen_current_government_name +]** ([+ bremen_current_government_parties +]).

Coalition seats: **[+ bremen_current_government_seats +] / 120**. Status: **[+ bremen_current_government_status +]**.

- @bremen_leader_kaisen
- @bremen_leader_spitta
- @bremen_leader_donandt

@bremen_leader_kaisen
title: Wilhelm Kaisen
subtitle: Available because the SPD is in the Bremen cabinet.
view-if: bremen_government = 1 or bremen_government = 2 or bremen_government = 3 or bremen_government = 4
on-arrival: bremen_leader = "Wilhelm Kaisen"
go-to: bremen_government_confirmed

@bremen_leader_spitta
title: Theodor Spitta
subtitle: Available because the DDP is in the Bremen cabinet and the SPD is not.
view-if: bremen_government = 5
on-arrival: bremen_leader = "Theodor Spitta"
go-to: bremen_government_confirmed

@bremen_leader_donandt
title: Martin Donandt
subtitle: Fallback leader for a Bremen cabinet without the SPD or DDP.
view-if: bremen_government = 0
on-arrival: bremen_leader = "Martin Donandt"
go-to: bremen_government_confirmed

@bremen_government_confirmed

on-arrival: {!
var ddpShare = Number(Q.bremen_ddp_votes_raw);
if (!isFinite(ddpShare)) { ddpShare = Number(Q.bremen_ddp_votes) || 0; }
var ddpSeats = Number(Q.bremen_ddp_r) || 0;
var totalSeats = Number(Q.bremen_landtag_total_seats) || 120;

var base = 0;
if (ddpShare >= 30) { base = 5; }
else if (ddpShare >= 20) { base = 4; }
else if (ddpShare >= 15) { base = 3; }
else if (ddpShare >= 10) { base = 2; }
else if (ddpShare >= 5) { base = 1; }

var coalitionParties = [];
var coalitionSeats = Number(Q.bremen_current_government_seats) || 0;
var gov = Number(Q.bremen_government) || 1;
if (gov === 1) { coalitionParties = ['spd', 'kpd']; }
else if (gov === 2) { coalitionParties = ['spd']; }
else if (gov === 3) { coalitionParties = ['spd', 'ddp']; }
else if (gov === 4) { coalitionParties = ['spd', 'ddp', 'dvp']; }
else if (gov === 5) { coalitionParties = ['dvp', 'dnvp', 'ddp', 'hausbesitzer']; }

var majorityThreshold = Math.floor(totalSeats / 2) + 1;
var pivotal = (coalitionSeats >= majorityThreshold && (coalitionSeats - ddpSeats) < majorityThreshold) ? 2 : 0;

var ddpInCoalition = coalitionParties.indexOf('ddp') !== -1;
var dominant = 0;
if (ddpInCoalition) {
  dominant = 1;
  for (var i = 0; i < coalitionParties.length; i += 1) {
    var party = coalitionParties[i];
    if (party === 'ddp') { continue; }
    var partySeats = Number(Q['bremen_' + party + '_r']) || 0;
    if (partySeats >= ddpSeats) { dominant = 0; break; }
  }
}

var hostilePenalty = 0;
if (coalitionParties.indexOf('dnvp') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('nsdap') !== -1) { hostilePenalty += 1; }
if (coalitionParties.indexOf('kpd') !== -1) { hostilePenalty += 1; }

var ddpLeaderPenalty = 0;
if (Q.bremen_leader === "DDP") { ddpLeaderPenalty = 1; }

var leverage = base + pivotal + dominant - hostilePenalty - ddpLeaderPenalty;
if (leverage < 0) { leverage = 0; }
if (leverage > 8) { leverage = 8; }
Q.bremen_leverage = leverage;
!}
= Bremen government formed

Coalition: **[+ bremen_current_government_name +]**

Parties: **[+ bremen_current_government_parties +]**

Seats: **[+ bremen_current_government_seats +] / 120**

Status: **[+ bremen_current_government_status +]**

Leader: **[+ bremen_leader +]**

Next Bremen election: **[+ bremen_next_election_year_preview +]**, in **[+ bremen_next_election_month_preview : month +]**.

- @root: Continue.
