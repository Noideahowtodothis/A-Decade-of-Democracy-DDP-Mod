on-arrival: {! Q.bremen_government = 2; if (typeof window !== 'undefined' && typeof window.updateBremenCoalitionOptions === 'function') { window.updateBremenCoalitionOptions(Q); } !}
go-to: bremen_leader_selection

@bremen_select_spd_ddp
